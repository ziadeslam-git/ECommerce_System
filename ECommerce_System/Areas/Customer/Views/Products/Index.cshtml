@model ECommerce_System.ViewModels.Customer.ProductController.ProductIndexCustomerVM
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    var isAr = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isAr ? ar : en;
    ViewData["Title"] = T("Products", "المنتجات");
    var products = Model?.Products ?? [];
    var productCount = products.Count();
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">@T("Products", "المنتجات")</h1>
        <a asp-area="Customer" asp-controller="Home" asp-action="Index"
           class="text-sm text-primary hover:underline inline-flex items-center gap-1">
            <span class="material-symbols-outlined text-base">arrow_back</span>@T("Home", "الرئيسية")
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

        <aside class="lg:col-span-3">
            <div class="lg:sticky lg:top-24 rounded-[1.75rem] border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/40">
                <div class="mb-5 flex items-start justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-black tracking-tight text-slate-900">@T("Refine Products", "تخصيص النتائج")</h2>
                        <p class="mt-1 text-sm leading-6 text-slate-500">@T("Use the filters below to narrow the collection quickly.", "استخدم الفلاتر بالأسفل لتضييق النتائج بسرعة.")</p>
                    </div>
                    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                        <span class="material-symbols-outlined">tune</span>
                    </div>
                </div>

                <form asp-area="Customer" asp-controller="Products" asp-action="Index" method="get" class="space-y-4">
                    <input type="hidden" name="search" value="@Model?.SearchQuery" />

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <label class="mb-2 block text-sm font-bold text-slate-800">@T("Category", "الفئة")</label>
                        @if (Model?.Categories != null)
                        {
                            <select name="categoryId" class="w-full rounded-xl border-slate-300 bg-white text-sm shadow-sm focus:border-primary focus:ring-primary">
                                <option value="">@T("All Categories", "كل الفئات")</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.Value"
                                            selected="@(Model.SelectedCategoryId?.ToString() == cat.Value)">
                                        @cat.Text
                                    </option>
                                }
                            </select>
                        }
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="mb-3 flex items-center justify-between gap-2">
                            <label class="block text-sm font-bold text-slate-800">@T("Price Range", "نطاق السعر")</label>
                            <span class="rounded-full bg-white px-3 py-1 text-[11px] font-semibold text-slate-500 shadow-sm">
                                @T("EGP", "جنيه")
                            </span>
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div class="space-y-1.5">
                                <span class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">@T("Min", "من")</span>
                                <input type="number"
                                       name="minPrice"
                                       value="@Model?.MinPrice"
                                       placeholder="0"
                                       class="w-full rounded-xl border-slate-300 bg-white text-sm shadow-sm focus:border-primary focus:ring-primary"
                                       min="0" />
                            </div>
                            <div class="space-y-1.5">
                                <span class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">@T("Max", "إلى")</span>
                                <input type="number"
                                       name="maxPrice"
                                       value="@Model?.MaxPrice"
                                       placeholder="9999"
                                       class="w-full rounded-xl border-slate-300 bg-white text-sm shadow-sm focus:border-primary focus:ring-primary"
                                       min="0" />
                            </div>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="mb-3 flex items-center justify-between gap-3">
                            <label class="block text-sm font-bold text-slate-800">@T("Sort By", "ترتيب حسب")</label>
                            <span class="rounded-full bg-white px-3 py-1 text-[11px] font-semibold text-slate-500 shadow-sm">
                                @productCount @T("items", "عنصر")
                            </span>
                        </div>

                        <select name="sort" class="w-full rounded-xl border-slate-300 bg-white text-sm shadow-sm focus:border-primary focus:ring-primary">
                            <option value="newest"     selected="@(Model?.Sort == "newest")">@T("Newest", "الأحدث")</option>
                            <option value="price_asc"  selected="@(Model?.Sort == "price_asc")">@T("Price ↑", "السعر ↑")</option>
                            <option value="price_desc" selected="@(Model?.Sort == "price_desc")">@T("Price ↓", "السعر ↓")</option>
                            <option value="rating"     selected="@(Model?.Sort == "rating")">@T("Rating", "التقييم")</option>
                        </select>
                    </div>

                    <div class="flex flex-col gap-3 pt-1">
                        <button class="w-full rounded-2xl bg-primary py-3 text-sm font-bold text-white shadow-lg shadow-primary/20 transition hover:bg-primary/90">
                            @T("Apply Filters", "تطبيق الفلاتر")
                        </button>

                        <a asp-area="Customer"
                           asp-controller="Products"
                           asp-action="Index"
                           class="inline-flex w-full items-center justify-center rounded-2xl border border-slate-300 py-3 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary">
                            @T("Clear Filters", "مسح الفلاتر")
                        </a>
                    </div>
                </form>
            </div>
        </aside>

        <div class="lg:col-span-9 space-y-5">
            <form asp-area="Customer" asp-controller="Products" asp-action="Index" method="get"
                  class="rounded-[1.75rem] border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/40">
                <input type="hidden" name="categoryId" value="@Model?.SelectedCategoryId" />
                <input type="hidden" name="minPrice" value="@Model?.MinPrice" />
                <input type="hidden" name="maxPrice" value="@Model?.MaxPrice" />
                <input type="hidden" name="sort" value="@Model?.Sort" />

                <label class="relative block">
                    <span class="material-symbols-outlined pointer-events-none absolute @(isAr ? "right-4" : "left-4") top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input type="search"
                           name="search"
                           value="@Model?.SearchQuery"
                           placeholder="@(T("Search products, styles, categories...", "ابحث عن منتجات أو ستايلات أو فئات..."))"
                           class="w-full rounded-2xl border-slate-300 bg-slate-50 py-3 @(isAr ? "pr-12 pl-4" : "pl-12 pr-4") text-sm shadow-sm focus:border-primary focus:ring-primary" />
                </label>
            </form>

            @if (!products.Any())
            {
                <div class="bg-white rounded-2xl border border-dashed border-slate-300 p-10 text-center text-slate-500">
                    @T("No products found.", "لا توجد منتجات مطابقة.")
                </div>
            }
            else
            {
                <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
                    @foreach (var p in products)
                    {
                        <article class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition flex flex-col h-full">
                            <div class="relative">
                                <a asp-area="Customer" asp-controller="Products" asp-action="Details"
                                   asp-route-id="@p.Id" class="block aspect-[4/5] bg-slate-100">
                                    <img src="@(p.MainImageUrl ?? "https://placehold.co/600x700")"
                                         class="w-full h-full object-cover" alt="@p.Name" loading="lazy" />
                                </a>
                                <div class="absolute left-3 top-3">
                                    @if (!p.HasStock)
                                    {
                                        <span class="inline-flex items-center gap-1.5 rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-[11px] font-bold text-rose-600 shadow-sm">
                                            <span class="h-1.5 w-1.5 rounded-full bg-rose-500"></span>
                                            @T("Out of Stock", "نفد المخزون")
                                        </span>
                                    }
                                    else if (p.AvailableStock <= 5)
                                    {
                                        <span class="inline-flex items-center gap-1.5 rounded-full border border-orange-200 bg-orange-50 px-3 py-1 text-[11px] font-bold text-orange-600 shadow-sm">
                                            <span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span>
                                            @T("Low Stock", "مخزون منخفض")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-[11px] font-bold text-emerald-600 shadow-sm">
                                            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                                            @T("In Stock", "متوفر")
                                        </span>
                                    }
                                </div>
                                <form asp-area="Customer" asp-controller="Wishlist" asp-action="Toggle"
                                      method="post"
                                      data-ajax-form="wishlist"
                                      data-active-text="@T("In Wishlist", "في المفضلة")"
                                      data-inactive-text="@T("Add to Wishlist", "أضف للمفضلة")"
                                      data-wishlist-active="@(p.IsInWishlist ? "true" : "false")"
                                      class="absolute top-3 right-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@p.Id" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit"
                                            data-wishlist-button
                                            data-wishlist-style="icon"
                                            class="inline-flex h-11 w-11 items-center justify-center rounded-full border shadow-md transition @(p.IsInWishlist ? "bg-rose-50 border-rose-200 text-rose-500" : "bg-white/95 border-slate-200 text-slate-700 hover:border-rose-200 hover:text-rose-500")"
                                            title="@(p.IsInWishlist ? T("In Wishlist", "في المفضلة") : T("Add to Wishlist", "أضف للمفضلة"))">
                                        <span data-heart-glyph class="text-2xl leading-none">@(p.IsInWishlist ? "♥" : "♡")</span>
                                    </button>
                                </form>
                            </div>
                            <div class="p-3 flex flex-col flex-grow">
                                <div class="space-y-2 flex-grow">
                                    <a asp-area="Customer" asp-controller="Products" asp-action="Details"
                                       asp-route-id="@p.Id"
                                       class="font-semibold line-clamp-1 hover:text-primary block">@p.Name</a>

                                    @if (p.MinVariantPrice.HasValue && p.MinVariantPrice < p.BasePrice)
                                    {
                                        <p class="font-bold text-primary">@p.MinVariantPrice.Value.ToString("0.00") EGP</p>
                                    }
                                    else
                                    {
                                        <p class="font-bold text-primary">@p.BasePrice.ToString("0.00") EGP</p>
                                    }

                                    <div class="text-amber-500 text-sm">
                                        @{
                                            int stars = (int)Math.Round(p.AverageRating);
                                            for (int s = 1; s <= 5; s++) { <text>@(s <= stars ? "★" : "☆")</text> }
                                        }
                                        <span class="text-slate-500 ms-1">(@p.ReviewCount)</span>
                                    </div>
                                </div>

                                <div class="mt-4 pt-3 border-t border-slate-100">
                                    @if (p.DefaultVariantId.HasValue && p.HasStock)
                                    {
                                        <form asp-area="Customer" asp-controller="Cart" asp-action="AddToCart"
                                              method="post"
                                              data-ajax-form="cart"
                                              class="w-full">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productVariantId" value="@p.DefaultVariantId.Value" />
                                            <input type="hidden" name="quantity" value="1" />
                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                            <button type="submit"
                                                    data-idle-text="@T("Add to Cart", "أضف للسلة")"
                                                    data-loading-text="@T("Adding...", "جارٍ الإضافة...")"
                                                    data-success-text="@T("Added!", "تمت الإضافة!")"
                                                    data-error-text="@T("Try again", "حاول مرة أخرى")"
                                                    data-idle-class="w-full rounded-2xl bg-gradient-to-br from-primary to-indigo-500 px-4 py-3 text-sm font-bold text-white shadow-[0_8px_20px_rgba(100,103,242,0.28)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_12px_24px_rgba(100,103,242,0.30)]"
                                                    data-loading-class="w-full rounded-2xl border border-slate-200 bg-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm cursor-wait"
                                                    data-success-class="w-full rounded-2xl border border-emerald-700 bg-emerald-700 px-4 py-3 text-sm font-bold text-white shadow-[0_8px_20px_rgba(20,108,46,0.24)]"
                                                    data-error-class="w-full rounded-2xl border border-rose-600 bg-rose-600 px-4 py-3 text-sm font-bold text-white shadow-[0_8px_20px_rgba(225,29,72,0.24)]"
                                                    class="w-full rounded-2xl bg-gradient-to-br from-primary to-indigo-500 px-4 py-3 text-sm font-bold text-white shadow-[0_8px_20px_rgba(100,103,242,0.28)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_12px_24px_rgba(100,103,242,0.30)]">
                                                <span class="inline-flex items-center justify-center gap-2">
                                                    <span class="material-symbols-outlined text-[18px]" style="font-variation-settings:'FILL' 1">shopping_cart</span>
                                                    <span>@T("Add to Cart", "أضف للسلة")</span>
                                                </span>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                disabled
                                                class="w-full rounded-2xl bg-slate-100 py-3 text-sm font-semibold text-slate-400 cursor-not-allowed">
                                            @T("Out of stock", "نفذ المخزون")
                                        </button>
                                    }
                                </div>

                                <div class="mt-2">
                                    <a asp-area="Customer" asp-controller="Products" asp-action="Details"
                                       asp-route-id="@p.Id"
                                       class="block w-full rounded-2xl border border-slate-300 bg-white py-2.5 text-center text-sm font-semibold text-primary transition hover:border-primary hover:bg-primary/5">
                                        @T("View Details", "عرض التفاصيل")
                                    </a>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }

            @if (Model != null && Model.TotalPages > 1)
            {
                <div class="flex justify-center gap-2 pt-3">
                    @if (Model.CurrentPage > 1)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-search="@Model.SearchQuery" asp-route-sort="@Model.Sort"
                           class="h-9 px-3 rounded-lg border border-slate-300 grid place-items-center text-sm hover:border-primary">←</a>
                    }
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index" asp-route-page="@i"
                           asp-route-search="@Model.SearchQuery" asp-route-sort="@Model.Sort"
                           class="h-9 w-9 rounded-lg border @(i == Model.CurrentPage ? "bg-primary text-white border-primary" : "border-slate-300 hover:border-primary") grid place-items-center text-sm">@i</a>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-search="@Model.SearchQuery" asp-route-sort="@Model.Sort"
                           class="h-9 px-3 rounded-lg border border-slate-300 grid place-items-center text-sm hover:border-primary">→</a>
                    }
                </div>
            }
        </div>
    </div>
</section>
