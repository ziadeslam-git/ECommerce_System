<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>@ViewData["Title"] - GiftPop!</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#6467f2",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101122",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined { font-size: 24px; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
    <div class="relative flex min-h-screen flex-col overflow-x-hidden">
        
        <!-- Top Navigation Bar -->
        <header class="sticky top-0 z-50 w-full border-b border-primary/10 bg-white/80 dark:bg-background-dark/80 backdrop-blur-md px-6 md:px-20 py-4">
            <div class="mx-auto flex max-w-7xl items-center justify-between">
                <div class="flex items-center gap-12">
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="flex items-center gap-3 group">
                        <div class="text-primary size-8 group-hover:scale-110 transition-transform">
                            <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                                <path d="M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z" fill="currentColor"></path>
                            </svg>
                        </div>
                        <h1 class="text-2xl font-black tracking-tighter text-primary">GiftPop!</h1>
                    </a>
                    
                    <nav class="hidden lg:flex items-center gap-8">
                        <a class="text-sm font-bold uppercase tracking-wider hover:text-primary transition-colors" href="#">T-Shirts</a>
                        <a class="text-sm font-bold uppercase tracking-wider hover:text-primary transition-colors" href="#">Gift Boxes</a>
                        <a class="text-sm font-bold uppercase tracking-wider hover:text-primary transition-colors" href="#">New Arrivals</a>
                        <a class="text-sm font-bold uppercase tracking-wider text-pink-500 transition-colors" href="#">Sale</a>
                    </nav>
                </div>
                
                <div class="flex items-center gap-4">
                    <div class="hidden sm:flex bg-primary/5 rounded-full px-4 py-2 items-center border border-primary/10">
                        <span class="material-symbols-outlined text-primary text-xl">search</span>
                        <input class="bg-transparent border-none focus:ring-0 text-sm w-40 placeholder:text-slate-400 outline-none" placeholder="Search vibes..." type="text"/>
                    </div>
                    
                    <a href="#" class="flex items-center justify-center rounded-full size-10 bg-primary text-white shadow-lg shadow-primary/30 hover:scale-105 transition-transform">
                        <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
                    </a>
                    
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <div class="flex items-center gap-2">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="flex items-center justify-center rounded-full size-10 bg-amber-50 text-amber-600 hover:bg-amber-100 dark:bg-amber-900/30 dark:text-amber-400 dark:hover:bg-amber-900/50 transition-colors" title="Admin Dashboard">
                                    <span class="material-symbols-outlined text-[20px]">shield_person</span>
                                </a>
                            }
                            <a asp-area="Identity" asp-controller="Profile" asp-action="Index" class="flex items-center justify-center rounded-full size-10 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors" title="My Profile">
                                <span class="material-symbols-outlined text-[20px]">person</span>
                            </a>
                            <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post" class="inline m-0 p-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="flex items-center justify-center rounded-full size-10 bg-slate-100 hover:bg-rose-100 text-slate-600 hover:text-rose-600 dark:bg-slate-800 dark:hover:bg-rose-900/50 transition-colors" title="Logout">
                                    <span class="material-symbols-outlined text-[20px]">logout</span>
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="flex items-center justify-center rounded-full px-5 h-10 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-[background-color,transform] hover:scale-105 hover:shadow-md text-sm font-bold text-slate-700 dark:text-slate-300 shadow-sm" title="Login">
                            Login
                        </a>
                    }
                </div>
            </div>
        </header>

        <main class="flex-grow">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="bg-white dark:bg-background-dark border-t border-primary/10 px-6 md:px-20 py-12">
            <div class="mx-auto max-w-7xl grid grid-cols-1 md:grid-cols-4 gap-12">
                <div class="space-y-6">
                    <div class="flex items-center gap-3">
                        <div class="text-primary size-6">
                            <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                                <path d="M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z" fill="currentColor"></path>
                            </svg>
                        </div>
                        <h2 class="text-xl font-black text-primary">GiftPop!</h2>
                    </div>
                    <p class="text-slate-500 text-sm leading-relaxed">The only shop where you can curate your own happiness. Based in LA, shipping worldwide.</p>
                    <div class="flex gap-4">
                        <a class="size-10 rounded-full bg-primary/5 flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all" href="#"><span class="material-symbols-outlined text-lg">public</span></a>
                        <a class="size-10 rounded-full bg-primary/5 flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all" href="#"><span class="material-symbols-outlined text-lg">diversity_3</span></a>
                        <a class="size-10 rounded-full bg-primary/5 flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all" href="#"><span class="material-symbols-outlined text-lg">chat</span></a>
                    </div>
                </div>
                <div class="space-y-4">
                    <h4 class="font-black uppercase text-xs tracking-widest text-slate-800 dark:text-slate-200">Shop</h4>
                    <ul class="space-y-3 text-sm text-slate-500 font-medium">
                        <li><a class="hover:text-primary" href="#">All T-Shirts</a></li>
                        <li><a class="hover:text-primary" href="#">Gift Boxes</a></li>
                        <li><a class="hover:text-primary" href="#">Stickers & Decals</a></li>
                        <li><a class="hover:text-primary" href="#">Holiday Specials</a></li>
                    </ul>
                </div>
                <div class="space-y-4">
                    <h4 class="font-black uppercase text-xs tracking-widest text-slate-800 dark:text-slate-200">Support</h4>
                    <ul class="space-y-3 text-sm text-slate-500 font-medium">
                        <li><a class="hover:text-primary" href="#">Track Order</a></li>
                        <li><a class="hover:text-primary" href="#">Shipping Policy</a></li>
                        <li><a class="hover:text-primary" href="#">Returns</a></li>
                        <li><a class="hover:text-primary" href="#">FAQs</a></li>
                    </ul>
                </div>
                <div class="space-y-4">
                    <h4 class="font-black uppercase text-xs tracking-widest text-slate-800 dark:text-slate-200">Contact</h4>
                    <ul class="space-y-3 text-sm text-slate-500 font-medium">
                        <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm">mail</span> hello@giftpop.shop</li>
                        <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm">location_on</span> Los Angeles, CA</li>
                    </ul>
                </div>
            </div>
            <div class="mx-auto max-w-7xl pt-12 mt-12 border-t border-slate-100 dark:border-slate-800 text-center md:text-left">
                <p class="text-xs text-slate-400 font-medium">© 2024 GiftPop! Inc. All rights reserved. Express yourself!</p>
            </div>
        </footer>
    </div>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
