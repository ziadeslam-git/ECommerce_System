@model ECommerce_System.ViewModels.Admin.ShipmentVM
@using ECommerce_System.Utilities

@{
    ViewData["Title"] = $"Edit Shipment — Order #{Model.OrderId}";
    Layout = "_AdminLayout";
}

@* ── Breadcrumb ── *@
<div class="mb-8">
    <nav class="flex items-center gap-2 text-sm text-slate-400 mb-2">
        <a asp-controller="Orders" asp-action="Index" class="hover:text-primary transition-colors">Orders</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId" class="hover:text-primary transition-colors">#ORD-@Model.OrderId</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-slate-700 dark:text-slate-300 font-medium">Edit Shipment</span>
    </nav>
    <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Edit Shipment</h2>
    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Update shipment details for Order #@Model.OrderId</p>
</div>

<div class="max-w-xl">
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">

        <div class="px-6 py-4 bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800 flex items-center gap-3">
            <div class="size-9 rounded-lg bg-sky-100 dark:bg-sky-900/20 flex items-center justify-center text-sky-600 dark:text-sky-400">
                <span class="material-symbols-outlined text-lg">edit_square</span>
            </div>
            <div>
                <p class="text-sm font-bold text-slate-800 dark:text-slate-200">Shipment #@Model.Id</p>
                <p class="text-xs text-slate-400">Editing for Order #@Model.OrderId</p>
            </div>
        </div>

        <form asp-action="Edit" asp-controller="Shipments" method="post" class="p-6 space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="OrderId" />

            @* Carrier *@
            <div>
                <label asp-for="Carrier" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Carrier</label>
                <input asp-for="Carrier" placeholder="e.g. FedEx, DHL, UPS"
                       class="w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all" />
                <span asp-validation-for="Carrier" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            @* Tracking Number *@
            <div>
                <label asp-for="TrackingNumber" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Tracking Number</label>
                <input asp-for="TrackingNumber" placeholder="e.g. FEX-9921-0012"
                       class="w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 px-3 py-2.5 text-sm font-mono focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all" />
                <span asp-validation-for="TrackingNumber" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            @* Status *@
            <div>
                <label asp-for="Status" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Shipment Status</label>
                <select asp-for="Status"
                        class="w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all">
                    @foreach (var s in ECommerce_System.ViewModels.Admin.ShipmentVM.ShipmentStatuses)
                    {
                        <option value="@s" selected="@(s == Model.Status)">@s</option>
                    }
                </select>
                <span asp-validation-for="Status" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            @* Estimated Delivery *@
            <div>
                <label asp-for="EstimatedDelivery" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">
                    Estimated Delivery Date <span class="font-normal text-slate-400">(optional)</span>
                </label>
                <input asp-for="EstimatedDelivery" type="date"
                       class="w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all" />
                <span asp-validation-for="EstimatedDelivery" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            @* Timestamps (read-only display) *@
            @if (Model.ShippedAt.HasValue || Model.DeliveredAt.HasValue)
            {
                <div class="bg-slate-50 dark:bg-slate-800/40 rounded-lg border border-slate-100 dark:border-slate-700 px-4 py-3 grid grid-cols-2 gap-4 text-xs">
                    @if (Model.ShippedAt.HasValue)
                    {
                        <div>
                            <p class="text-slate-400 uppercase tracking-wider mb-1">Shipped At</p>
                            <p class="font-semibold text-slate-700 dark:text-slate-300">@Model.ShippedAt.Value.ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                    }
                    @if (Model.DeliveredAt.HasValue)
                    {
                        <div>
                            <p class="text-slate-400 uppercase tracking-wider mb-1">Delivered At</p>
                            <p class="font-semibold text-slate-700 dark:text-slate-300">@Model.DeliveredAt.Value.ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                    }
                </div>
            }

            @* Info Banner *@
            <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800 rounded-lg px-4 py-3 flex items-start gap-3 text-xs text-blue-700 dark:text-blue-400">
                <span class="material-symbols-outlined text-sm flex-shrink-0 mt-0.5">info</span>
                <span>Changing status to <strong>Shipped</strong>/<strong>OutForDelivery</strong> → Order becomes <strong>Shipped</strong>. Changing to <strong>Delivered</strong> → Order becomes <strong>Delivered</strong>.</span>
            </div>

            @* Actions *@
            <div class="flex items-center gap-3 pt-2">
                <button type="submit"
                        class="flex items-center gap-2 px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-bold hover:opacity-90 shadow-md shadow-primary/20 transition-all">
                    <span class="material-symbols-outlined text-sm">save</span>
                    Save Changes
                </button>
                <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId"
                   class="px-5 py-2.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
