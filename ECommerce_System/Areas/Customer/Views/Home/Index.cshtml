@model HomeIndexVM
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    ViewData["Title"] = "Home";
    var featured = Model?.FeaturedProducts ?? [];
    var categories = Model?.Categories ?? [];
    var isAr = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isAr ? ar : en;
}

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="rounded-3xl bg-gradient-to-r from-primary/10 to-indigo-100 p-8 md:p-12">
        <h1 class="text-3xl md:text-5xl font-black text-slate-900">@T("Welcome to Smart Store","مرحباً بك في سمارت ستور")</h1>
        <p class="text-slate-600 mt-3">@T("Discover curated products and gifts picked for you.","اكتشف منتجات وهدايا مختارة خصيصاً لك.")</p>
        <div class="mt-6 flex gap-3">
            <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="px-5 py-3 rounded-lg bg-primary text-white font-semibold">@T("Products","المنتجات")</a>
            <a asp-area="Customer" asp-controller="Wishlist" asp-action="Index" class="px-5 py-3 rounded-lg border border-slate-300 bg-white font-semibold">@T("Wishlist","المفضلة")</a>
        </div>
    </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-bold">@T("Featured Products","المنتجات الحديثة")</h2>
        <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="text-primary text-sm font-semibold hover:underline">@T("View all","عرض الكل")</a>
    </div>

    @if (!featured.Any())
    {
        <div class="bg-white border border-dashed border-slate-300 rounded-2xl p-10 text-center text-slate-500">@T("No featured products yet.","لا توجد منتجات مميزة حالياً.")</div>
    }
    else
    {
        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
            @foreach (var p in featured)
            {
                <article class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-lg transition">
                    <a asp-area="Customer" asp-controller="Products" asp-action="Details" asp-route-id="@p.Id" class="block aspect-[4/5] bg-slate-100">
                        <img src="@(p.MainImageUrl ?? "https://placehold.co/600x700")" alt="@p.Name" class="w-full h-full object-cover" />
                    </a>
                    <div class="p-3 space-y-1">
                        <a asp-area="Customer" asp-controller="Products" asp-action="Details" asp-route-id="@p.Id" class="font-semibold line-clamp-1 hover:text-primary">@p.Name</a>
                        <p class="text-xs text-slate-500">@p.CategoryName</p>
                        <p class="font-bold text-primary">@((p.MinVariantPrice > 0 ? p.MinVariantPrice : p.BasePrice).ToString("0.00")) EGP</p>
                        <div class="text-amber-500 text-sm">@(new string('★', (int)Math.Round(p.AverageRating == 0 ? 5 : p.AverageRating)))</div>
                    </div>
                </article>
            }
        </div>
    }
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h2 class="text-2xl font-bold mb-4">@T("Categories","الفئات")</h2>
    @if (!categories.Any())
    {
        <div class="bg-white border border-dashed border-slate-300 rounded-2xl p-10 text-center text-slate-500">@T("No categories available.","لا توجد فئات متاحة.")</div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var c in categories)
            {
                <a asp-area="Customer" asp-controller="Products" asp-action="Index" asp-route-category="@c.Name"
                   class="bg-white rounded-2xl border border-slate-200 p-5 hover:border-primary hover:shadow-md transition">
                    <p class="text-lg font-bold">@c.Name</p>
                    <p class="text-sm text-slate-500 mt-1">@c.ProductCount @T("products","منتج")</p>
                </a>
            }
        </div>
    }
</section>
