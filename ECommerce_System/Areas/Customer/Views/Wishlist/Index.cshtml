@using ECommerce_System.ViewModels.Customer
@inject Microsoft.Extensions.Localization.IStringLocalizer<ECommerce_System.Resources.SharedResource> SR
@model WishlistIndexVM

@{
    ViewData["Title"] = SR["MyWishlist"];
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">@SR["MyWishlist"]</h1>

    @if (Model.IsEmpty)
    {
        <div class="bg-white p-8 rounded-lg shadow-sm border border-slate-200 text-center">
            <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">favorite</span>
            <h2 class="text-xl font-semibold text-slate-700">@SR["WishlistEmpty"]</h2>
            <p class="text-slate-500 mt-2">@SR["WishlistEmptyHint"]</p>
            <a asp-area="Customer" asp-controller="Products" asp-action="Index"
               class="mt-4 inline-block bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors">
                @SR["BrowseProducts"]
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
            @foreach (var item in Model.Items)
            {
                <article data-wishlist-card class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition flex flex-col h-full">
                    <div class="relative">
                        <a asp-area="Customer" asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId"
                           class="block aspect-[4/5] bg-slate-100">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.ProductName"
                                     class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <span class="material-symbols-outlined text-slate-300 text-4xl">image</span>
                                </div>
                            }
                        </a>

                        <form asp-action="Toggle"
                              method="post"
                              data-ajax-form="wishlist"
                              data-active-text="In Wishlist"
                              data-inactive-text="Add to Wishlist"
                              data-wishlist-active="true"
                              data-remove-card-on-inactive="true"
                              data-remove-card-closest="article"
                              data-remaining-cards-selector="[data-wishlist-card]"
                              class="absolute top-3 right-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit"
                                    data-wishlist-button
                                    data-wishlist-style="icon"
                                    class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-rose-200 bg-rose-50 text-rose-500 shadow-md transition hover:bg-rose-100"
                                    title="@SR["RemoveFromWishlist"]">
                                <span data-heart-glyph class="text-2xl leading-none">♥</span>
                            </button>
                        </form>
                    </div>

                    <div class="p-3 flex flex-col flex-grow">
                        <div class="space-y-2 flex-grow">
                            <a asp-area="Customer" asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId"
                               class="font-semibold line-clamp-1 hover:text-primary block">@item.ProductName</a>

                            <p class="font-bold text-primary">@item.BasePrice.ToString("0.00") EGP</p>

                            <div class="text-amber-500 text-sm">
                                @{
                                    int stars = (int)Math.Round(item.AverageRating);
                                    for (int s = 1; s <= 5; s++) { <text>@(s <= stars ? "★" : "☆")</text>; }
                                }
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-t border-slate-100">
                            <form asp-action="MoveToCart" method="post" class="w-full">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit"
                                        class="w-full rounded-2xl bg-gradient-to-br from-primary to-indigo-500 px-4 py-3 text-sm font-bold text-white shadow-[0_8px_20px_rgba(100,103,242,0.28)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_12px_24px_rgba(100,103,242,0.30)]">
                                    <span class="inline-flex items-center justify-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings:'FILL' 1">shopping_cart</span>
                                        <span>@SR["AddToCart"]</span>
                                    </span>
                                </button>
                            </form>
                        </div>

                        <div class="mt-2">
                            <a asp-area="Customer" asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId"
                               class="block w-full rounded-2xl border border-slate-300 bg-white py-2.5 text-center text-sm font-semibold text-primary transition hover:border-primary hover:bg-primary/5">
                                @SR["ViewDetails"]
                            </a>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>
