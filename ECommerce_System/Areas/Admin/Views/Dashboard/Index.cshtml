    </div>
</div>

<!-- Section 3: Monthly Revenue Bar Chart (Full Width) -->
<div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-100 dark:border-slate-800 shadow-sm p-8">
    <h3 class="text-slate-800 dark:text-slate-100 font-bold mb-8">Monthly Revenue</h3>
    <div class="h-64 flex flex-col justify-end">
        <div class="flex-1 flex items-end justify-between gap-4 px-2 relative">
            <!-- Chart Gridlines -->
            <div class="absolute inset-0 flex flex-col justify-between pointer-events-none">
                <div class="border-t border-slate-100 dark:border-slate-800 w-full"></div>
                <div class="border-t border-slate-100 dark:border-slate-800 w-full"></div>
                <div class="border-t border-slate-100 dark:border-slate-800 w-full"></div>
                <div class="border-t border-slate-100 dark:border-slate-800 w-full"></div>
            </div>
            
            <!-- Bars -->
            <div class="relative flex-1 group h-full flex flex-col justify-end items-center">
                <div class="w-full max-w-[40px] bg-primary/40 group-hover:bg-primary rounded-t-lg transition-all duration-300" style="height: 45%;"></div>
                <span class="mt-4 text-[11px] text-slate-400 font-medium">Jan</span>
            </div>
            <div class="relative flex-1 group h-full flex flex-col justify-end items-center">
                <div class="w-full max-w-[40px] bg-primary/40 group-hover:bg-primary rounded-t-lg transition-all duration-300" style="height: 55%;"></div>
                <span class="mt-4 text-[11px] text-slate-400 font-medium">Feb</span>
            </div>
            <div class="relative flex-1 group h-full flex flex-col justify-end items-center">
