@model IEnumerable<ECommerce_System.Models.WishlistItem>
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    ViewData["Title"] = SR["Wishlist"];
    var items = Model ?? Enumerable.Empty<ECommerce_System.Models.WishlistItem>();
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">@SR["Wishlist"]</h1>
        <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="text-sm text-primary hover:underline">@SR["BrowseProducts"]</a>
    </div>

    @if (!items.Any())
    {
        <div class="bg-white border border-dashed border-slate-300 rounded-2xl p-12 text-center"><p class="mb-3 text-slate-600">@SR["WishlistEmpty"]</p><a asp-area="Customer" asp-controller="Products" asp-action="Index" class="inline-flex px-4 py-2 rounded-lg bg-primary text-white">@SR["StartShopping"]</a></div>
    }
    else
    {
        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
            @foreach (var w in items)
            {
                <article class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-lg transition">
                    <a asp-area="Customer" asp-controller="Products" asp-action="Details" asp-route-id="@w.ProductId" class="block aspect-[4/5] bg-slate-100"><img src="@(w.Product?.Images?.FirstOrDefault(i => i.IsMain)?.ImageUrl ?? w.Product?.Images?.FirstOrDefault()?.ImageUrl ?? "https://placehold.co/600x700")" class="w-full h-full object-cover" alt="@w.Product?.Name" /></a>
                    <div class="p-3 space-y-2">
                        <p class="font-semibold line-clamp-1">@w.Product?.Name</p>
                        <p class="text-primary font-bold">@((w.Product?.BasePrice ?? 0m).ToString("0.00")) EGP</p>
                        <div class="flex gap-2">
                            <form asp-area="Customer" asp-controller="Wishlist" asp-action="Remove" method="post" class="flex-1" data-loading="true">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@w.Id" /><button class="w-full rounded-lg border border-rose-200 text-rose-700 py-2 text-sm">@SR["Remove"]</button></form>
                            <form asp-area="Customer" asp-controller="Cart" asp-action="Add" method="post" class="flex-1" data-loading="true">@Html.AntiForgeryToken()<input type="hidden" name="productId" value="@w.ProductId" /><button class="w-full rounded-lg bg-primary text-white py-2 text-sm">@SR["MoveToCart"]</button></form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
