@model ECommerce_System.Models.Order
@{
    ViewData["Title"] = "Order Details";
    var order = Model;
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex items-center justify-between">
        <a asp-area="Customer" asp-controller="Orders" asp-action="Index" class="text-sm text-primary hover:underline inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">arrow_back</span>Back to Orders</a>
        @if (order?.Status == "Pending")
        {
            <form asp-area="Customer" asp-controller="Orders" asp-action="Cancel" method="post" data-loading="true">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@order.Id" /><button class="px-4 py-2 rounded-lg bg-rose-600 text-white">Cancel Order</button></form>
        }
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-5">
        <h1 class="text-xl font-bold mb-4">Order #@order?.Id</h1>
        <div class="grid sm:grid-cols-4 gap-2 text-xs text-center">
            @foreach (var step in new[] { "Pending", "Confirmed", "Shipped", "Delivered" })
            { <div class="rounded-lg px-2 py-2 @(order?.Status==step?"bg-primary text-white":"bg-slate-100")">@step</div> }
        </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl overflow-auto">
        <table class="w-full text-sm"><thead class="bg-slate-50"><tr><th class="p-3 text-left">Item</th><th class="p-3 text-left">Qty</th><th class="p-3 text-left">Price</th></tr></thead>
        <tbody>@foreach (var i in order?.OrderItems ?? new List<ECommerce_System.Models.OrderItem>()) {<tr class="border-t border-slate-100"><td class="p-3">@i.ProductName (@i.Size / @i.Color)</td><td class="p-3">@i.Quantity</td><td class="p-3">@i.UnitPrice.ToString("0.00")</td></tr>}</tbody></table>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white border border-slate-200 rounded-2xl p-5 space-y-2"><h2 class="font-semibold">Shipping</h2><p class="text-sm text-slate-600">Carrier: @(order?.Shipment?.Carrier ?? "TBD")</p><p class="text-sm text-slate-600">Tracking: @(order?.Shipment?.TrackingNumber ?? "Not available")</p><p class="text-sm text-slate-600">Estimated Delivery: @(order?.Shipment?.EstimatedDelivery.ToString() ?? "TBD")</p></div>
        <div class="bg-white border border-slate-200 rounded-2xl p-5 space-y-2"><h2 class="font-semibold">Totals</h2><p class="text-sm">Subtotal: @((order?.Subtotal ?? 0m).ToString("0.00")) EGP</p><p class="text-sm">Discount: @((order?.DiscountAmount ?? 0m).ToString("0.00")) EGP</p><p class="font-bold">Total: @((order?.TotalAmount ?? 0m).ToString("0.00")) EGP</p></div>
    </div>
</section>
