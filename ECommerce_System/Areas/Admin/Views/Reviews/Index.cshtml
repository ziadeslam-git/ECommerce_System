@model IEnumerable<ReviewVM>
@{
    ViewData["Title"] = "Reviews Management";
    var reviews = Model.ToList();
    int currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    int totalCount = ViewBag.TotalCount is int tc ? tc : reviews.Count;
    int pageSize = ViewBag.PageSize is int ps ? ps : 10;
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
    int startItem = totalCount == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    int endItem = totalCount == 0 ? 0 : startItem + reviews.Count - 1;
}

@section Styles {
    <style>
        .custom-shadow { box-shadow: 0 20px 40px rgba(15, 23, 42, 0.05); }
    </style>
}

<div class="space-y-8 font-inter">
    <!-- Page Header -->
    <div class="flex justify-between items-end mb-8">
        <div>
            <h2 class="text-3xl font-bold text-on-surface tracking-tight mb-1">Product Reviews</h2>
            <p class="text-on-surface-variant text-sm">Monitor and manage customer feedback across your catalog.</p>
        </div>
        <div class="flex gap-3">
            <a asp-action="ExportWord" class="flex items-center gap-2 px-4 py-2 bg-surface-container text-on-surface font-semibold rounded-xl text-sm hover:bg-surface-container-highest transition-all shadow-sm border border-transparent hover:border-surface-variant">
                <span class="material-symbols-outlined text-[18px]">download</span>
                Export Word
            </a>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="flex flex-wrap items-center gap-1 bg-surface-container-low p-1.5 rounded-2xl w-fit">
        <a asp-action="Index" class="px-5 py-2 rounded-xl text-sm font-bold transition-all shadow-sm @(string.IsNullOrEmpty(ViewBag.StatusFilter) ? "bg-white text-primary" : "text-on-surface-variant hover:bg-white/50")">
            All <span class="ml-1 opacity-60">@ViewBag.AllCount</span>
        </a>
        <a asp-action="Index" asp-route-status="Pending" class="px-5 py-2 rounded-xl text-sm font-semibold transition-all @(ViewBag.StatusFilter == "Pending" ? "bg-white text-primary shadow-sm" : "text-on-surface-variant hover:bg-white/50")">
            Pending <span class="ml-1 px-1.5 py-0.5 rounded-full bg-amber-100 text-amber-700 text-[10px]">@ViewBag.PendingCount</span>
        </a>
        <a asp-action="Index" asp-route-status="Approved" class="px-5 py-2 rounded-xl text-sm font-semibold transition-all @(ViewBag.StatusFilter == "Approved" ? "bg-white text-primary shadow-sm" : "text-on-surface-variant hover:bg-white/50")">
            Approved <span class="ml-1 px-1.5 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-[10px]">@ViewBag.ApprovedCount</span>
        </a>
        <a asp-action="Index" asp-route-status="Rejected" class="px-5 py-2 rounded-xl text-sm font-semibold transition-all @(ViewBag.StatusFilter == "Rejected" ? "bg-white text-primary shadow-sm" : "text-on-surface-variant hover:bg-white/50")">
            Rejected <span class="ml-1 px-1.5 py-0.5 rounded-full bg-rose-100 text-rose-700 text-[10px]">@ViewBag.RejectedCount</span>
        </a>
    </div>

    <!-- Reviews Table Area -->
    <div class="bg-surface-container-lowest rounded-3xl overflow-hidden custom-shadow border border-slate-100 dark:border-slate-800">
        <div class="space-y-3 p-4 md:hidden">
            @foreach (var review in reviews)
            {
                <article class="rounded-[18px] border border-slate-200 bg-slate-50/80 p-4 shadow-sm">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="text-sm font-bold text-slate-900">@review.ProductName</p>
                            <p class="mt-1 text-xs font-semibold text-slate-500">@review.UserName</p>
                        </div>
                        @if (review.IsApproved)
                        {
                            <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-[10px] font-bold uppercase text-emerald-700">Approved</span>
                        }
                        else if (review.IsRejected)
                        {
                            <span class="inline-flex rounded-full bg-rose-100 px-3 py-1 text-[10px] font-bold uppercase text-rose-700">Rejected</span>
                        }
                        else
                        {
                            <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-[10px] font-bold uppercase text-amber-700">Pending</span>
                        }
                    </div>

                    <div class="mt-3 flex text-amber-400">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' @(i <= review.Rating ? "1" : "0");">star</span>
                        }
                    </div>
                    <p class="mt-3 text-sm text-slate-600">@(review.IsRejected ? "[Rejected: Hidden Content]" : $"\"{review.Comment}\"")</p>

                    <div class="mt-4 flex items-center justify-between">
                        <p class="text-xs font-semibold text-slate-400">@review.CreatedAt.ToString("MMM dd, yyyy")</p>
                        <div class="flex items-center gap-2">
                            @if (!review.IsApproved && !review.IsRejected)
                            {
                                <form asp-action="Approve" method="post" class="inline">
                                    <input type="hidden" name="id" value="@review.Id" />
                                    <button type="submit" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 transition hover:bg-emerald-100">
                                        <span class="material-symbols-outlined text-[18px]">check_circle</span>
                                    </button>
                                </form>
                                <form asp-action="Reject" method="post" class="inline">
                                    <input type="hidden" name="id" value="@review.Id" />
                                    <button type="submit" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-rose-50 text-error transition hover:bg-rose-100">
                                        <span class="material-symbols-outlined text-[18px]">cancel</span>
                                    </button>
                                </form>
                            }
                            <a asp-action="Details" asp-route-id="@review.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-slate-600 shadow-sm transition hover:bg-slate-100">
                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                            </a>
                            <form asp-action="Delete" method="post" class="inline" onsubmit="return confirm('Delete this review completely?');">
                                <input type="hidden" name="id" value="@review.Id" />
                                <button type="submit" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-slate-500 shadow-sm transition hover:bg-rose-50 hover:text-error">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            }
            @if (!reviews.Any())
            {
                <div class="rounded-[18px] border border-dashed border-slate-200 bg-slate-50 p-6 text-center text-sm text-slate-500">
                    No reviews found matching your criteria.
                </div>
            }
        </div>

        <div class="hidden overflow-x-auto md:block">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low/50">
                        <th class="py-5 px-6 w-12 text-center">
                            <input type="checkbox" class="rounded border-outline-variant text-primary focus:ring-primary" />
                        </th>
                        <th class="py-5 px-4 font-bold text-[11px] uppercase tracking-widest text-on-surface-variant">Product</th>
                        <th class="py-5 px-4 font-bold text-[11px] uppercase tracking-widest text-on-surface-variant">Customer</th>
                        <th class="py-5 px-4 font-bold text-[11px] uppercase tracking-widest text-on-surface-variant">Rating</th>
                        <th class="py-5 px-4 font-bold text-[11px] uppercase tracking-widest text-on-surface-variant">Summary</th>
                        <th class="py-5 px-4 font-bold text-[11px] uppercase tracking-widest text-on-surface-variant">Date</th>
                        <th class="py-5 px-4 font-bold text-[11px] uppercase tracking-widest text-on-surface-variant text-center">Status</th>
                        <th class="py-5 px-6 text-right font-bold text-[11px] uppercase tracking-widest text-on-surface-variant">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-container">
                    @foreach (var review in reviews)
                    {
                        var isPending = !review.IsApproved && !review.IsRejected;
                        var rowClass = isPending ? "group bg-indigo-50/20 transition-colors hover:bg-indigo-50/40" : "group hover:bg-surface-container-low transition-colors";

                        <tr class="@rowClass">
                            <td class="py-6 px-6 align-top text-center">
                                <input type="checkbox" class="rounded border-outline-variant text-primary focus:ring-primary" />
                            </td>
                            <td class="py-6 px-4 align-top">
                                <p class="text-[13px] font-bold text-on-surface leading-tight">@review.ProductName</p>
                                <p class="text-[10px] font-mono text-secondary mt-0.5">ID: @review.ProductId</p>
                            </td>
                            <td class="py-6 px-4 align-top">
                                <p class="text-[13px] font-semibold text-on-surface truncate max-w-[120px]">@review.UserName</p>
                            </td>
                            <td class="py-6 px-4 align-top">
                                <div class="flex text-amber-400">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' @(i <= review.Rating ? "1" : "0");">star</span>
                                    }
                                </div>
                            </td>
                            <td class="py-6 px-4 align-top max-w-xs">
                                @if (review.IsRejected)
                                {
                                    <p class="text-[13px] text-error/80 truncate font-medium">[Rejected: Hidden Content]</p>
                                }
                                else
                                {
                                    <p class="text-[13px] text-on-surface-variant line-clamp-2 italic">"@review.Comment"</p>
                                }
                            </td>
                            <td class="py-6 px-4 align-top">
                                <p class="text-[13px] text-on-surface-variant whitespace-nowrap">@review.CreatedAt.ToString("MMM dd, yyyy")</p>
                            </td>
                            <td class="py-6 px-4 align-top text-center">
                                @if (review.IsApproved)
                                {
                                    <span class="inline-flex px-3 py-1 rounded-full text-[10px] font-bold bg-emerald-100 text-emerald-700 uppercase tracking-tighter">Approved</span>
                                }
                                else if (review.IsRejected)
                                {
                                    <span class="inline-flex px-3 py-1 rounded-full text-[10px] font-bold bg-rose-100 text-rose-700 uppercase tracking-tighter">Rejected</span>
                                }
                                else
                                {
                                    <span class="inline-flex px-3 py-1 rounded-full text-[10px] font-bold bg-amber-100 text-amber-700 uppercase tracking-tighter shadow-[0_2px_4px_rgba(217,119,6,0.15)]">Pending</span>
                                }
                            </td>
                            <td class="py-6 px-6 align-top text-right">
                                <div class="flex items-center justify-end gap-1">
                                    @if (!review.IsApproved && !review.IsRejected)
                                    {
                                        <form asp-action="Approve" method="post" class="inline">
                                            <input type="hidden" name="id" value="@review.Id" />
                                            <button type="submit" class="p-1.5 text-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors" title="Approve">
                                                <span class="material-symbols-outlined text-[20px]">check_circle</span>
                                            </button>
                                        </form>
                                        <form asp-action="Reject" method="post" class="inline">
                                            <input type="hidden" name="id" value="@review.Id" />
                                            <button type="submit" class="p-1.5 text-error hover:bg-error-container/50 rounded-lg transition-colors" title="Reject">
                                                <span class="material-symbols-outlined text-[20px]">cancel</span>
                                            </button>
                                        </form>
                                    }
                                    <a asp-action="Details" asp-route-id="@review.Id" class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-lg transition-colors" title="View Details">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </a>
                                    <form asp-action="Delete" method="post" class="inline" onsubmit="return confirm('Delete this review completely?');">
                                        <input type="hidden" name="id" value="@review.Id" />
                                        <button type="submit" class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error-container/20 rounded-lg transition-colors" title="Delete">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!reviews.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-16">
                                <span class="material-symbols-outlined text-4xl text-slate-300 mb-3 block">rate_review</span>
                                <p class="text-slate-500 font-medium">No reviews found matching your criteria.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="px-8 py-5 border-t border-surface-container flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <p class="text-xs text-on-surface-variant font-medium">
                    Showing <span class="font-semibold text-slate-700">@startItem</span>
                    to <span class="font-semibold text-slate-700">@endItem</span>
                    of <span class="font-semibold text-slate-700">@totalCount</span> reviews
                </p>
                <div class="flex flex-wrap items-center gap-2">
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-status="@ViewBag.StatusFilter"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == 1 ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                        Previous
                    </a>

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        if (i == currentPage)
                        {
                            <button class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-primary bg-primary px-3 text-xs font-bold text-white shadow-md shadow-primary/20">@i</button>
                        }
                        else
                        {
                            <a asp-action="Index" asp-route-page="@i" asp-route-status="@ViewBag.StatusFilter" class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-slate-200 bg-white px-3 text-xs font-bold text-slate-600 transition-all hover:border-primary/30 hover:text-primary">@i</a>
                        }
                    }

                    <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-status="@ViewBag.StatusFilter"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == totalPages ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        Next
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

