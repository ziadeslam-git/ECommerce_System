@{
    ViewData["Title"] = "Express Your Vibe";
    Layout = "_CustomerLayout";
}

<!-- Hero Section -->
<section class="px-6 md:px-20 py-8">
    <div class="mx-auto max-w-7xl">
        <div class="relative overflow-hidden rounded-3xl bg-primary/10 p-8 md:p-16 flex flex-col md:flex-row items-center gap-12">
            <div class="z-10 flex-1 space-y-6">
                <span class="inline-block px-4 py-1 rounded-full bg-white text-primary text-xs font-black uppercase tracking-widest shadow-sm">Collection 2024</span>
                <h2 class="text-5xl md:text-7xl font-black leading-tight tracking-tighter italic text-slate-900 dark:text-white">Wear Your <span class="text-primary">Mood.</span></h2>
                <p class="text-lg text-slate-600 dark:text-slate-400 max-w-md font-medium leading-relaxed">Exclusive high-quality tees and curated gift boxes for the bold and the bright. Express yourself without saying a word.</p>
                <div class="flex flex-wrap gap-4 pt-4">
                    <button class="px-8 py-4 bg-primary text-white rounded-xl font-bold text-lg hover:scale-105 transition-transform shadow-xl shadow-primary/40">Shop T-Shirts</button>
                    <button class="px-8 py-4 bg-white dark:bg-slate-800 border-2 border-primary text-primary rounded-xl font-bold text-lg hover:bg-primary/5 transition-colors">Gift Guide</button>
                </div>
            </div>
            <div class="flex-1 w-full max-w-md">
                <div class="aspect-square rounded-3xl bg-gradient-to-br from-primary to-pink-400 rotate-3 overflow-hidden shadow-2xl relative">
                    <img class="w-full h-full object-cover -rotate-3 scale-110" data-alt="Cool young person wearing a graphic oversized lavender t-shirt" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZJH33Dd2knG8yZHyPKYVSF48OYBtT6jGI65kqAaIwT4u-W2_K1a8WrhmkAhoJsgsVQoBnG8DDrnBESPhWKhWI-b3nTWZc4BDiNFPSnodP2-3I5hWlZvSsNrPfxNG-bFtEnBJ2EZfVy_CSC-qGLPgq-_pmgK3qpedicPeAZE2CblHrcp8kG61mzz-nfdkDv7ZWMM4IvR5g5rMNN6FYTw6uKt-SpwFvkBD2UfAeiFAadVMMeQSvLPM2rggE_uVBkmTeMRG6rgxUd6Id"/>
                    <div class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur rounded-2xl p-4 shadow-lg flex items-center justify-between">
                        <div>
                            <p class="text-xs font-bold text-slate-500 uppercase">Featured Design</p>
                            <p class="font-black text-slate-900">Electric Soul Tee</p>
                        </div>
                        <span class="text-primary font-black">$32.00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Build Your Own Box Section -->
<section class="px-6 md:px-20 py-12">
