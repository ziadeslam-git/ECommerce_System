@model CartIndexVM
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    ViewData["Title"] = SR["Cart"];
    var items = Model?.Items ?? [];
    decimal subtotal = Model?.Subtotal ?? 0m;
    decimal total = Model?.Total ?? subtotal;
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-bold">@SR["Cart"]</h1>
        <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="text-sm text-primary hover:underline">@SR["ContinueShopping"]</a>
    </div>

    @if (Model?.IsEmpty ?? true)
    {
        <div class="space-y-4 rounded-2xl border border-dashed border-slate-300 bg-white p-12 text-center">
            <p class="text-2xl">🛒</p>
            <h2 class="text-xl font-semibold">@SR["CartEmpty"]</h2>
            <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="inline-flex rounded-lg bg-primary px-5 py-2 text-white">@SR["BrowseProducts"]</a>
        </div>
    }
    else
    {
        <div class="grid gap-6 lg:grid-cols-5">
            <div class="divide-y divide-slate-200 rounded-2xl border border-slate-200 bg-white lg:col-span-3">
                @foreach (var item in items)
                {
                    <div class="flex gap-4 p-4">
                        <img src="@(item.ImageUrl ?? "https://placehold.co/120")" class="h-24 w-24 rounded-lg bg-slate-100 object-cover" alt="@item.ProductName" />
                        <div class="flex-1 space-y-1">
                            <p class="font-semibold">@item.ProductName</p>
                            <p class="text-xs text-slate-500">Variant: @item.Size / @item.Color</p>
                            <p class="text-sm">@item.UnitPrice.ToString("0.00") EGP</p>
                            <form asp-area="Customer" asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="flex items-center gap-2" data-loading="true">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                <input type="number" min="1" max="@Math.Max(1, item.AvailableStock)" name="quantity" value="@item.Quantity" class="w-20 rounded-lg border-slate-300" />
                                <button class="rounded border border-slate-300 px-3 py-1 text-xs">@SR["Update"]</button>
                            </form>
                        </div>
                        <div class="space-y-2 text-right">
                            <p class="font-semibold">@item.LineTotal.ToString("0.00")</p>
                            <form asp-area="Customer" asp-controller="Cart" asp-action="Remove" method="post" data-loading="true">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                <button class="text-sm text-rose-600">@SR["Remove"]</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
            <aside class="h-fit space-y-4 rounded-2xl border border-slate-200 bg-white p-5 lg:col-span-2">
                <h2 class="font-semibold">@SR["OrderSummary"]</h2>
                <div class="flex justify-between text-sm"><span>@SR["Subtotal"]</span><span>@subtotal.ToString("0.00") EGP</span></div>
                <form asp-area="Customer" asp-controller="Cart" asp-action="ApplyCoupon" method="post" class="flex gap-2" data-loading="true">
                    @Html.AntiForgeryToken()
                    <input type="text" name="couponCode" value="@Model?.CouponCode" class="flex-1 rounded-lg border-slate-300" placeholder="@SR["CouponCode"]" />
                    <button class="rounded-lg border border-slate-300 px-3">@SR["Apply"]</button>
                </form>
                <div class="flex justify-between text-lg font-bold"><span>@SR["Total"]</span><span>@total.ToString("0.00") EGP</span></div>
                <a asp-area="Customer" asp-controller="Cart" asp-action="Checkout" class="block rounded-lg bg-primary py-3 text-center font-semibold text-white">@SR["Checkout"]</a>
            </aside>
        </div>
    }
</section>
