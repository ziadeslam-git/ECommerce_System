@model IEnumerable<ECommerce_System.Models.Order>
@{
    ViewData["Title"] = "My Orders";
    var orders = Model ?? Enumerable.Empty<ECommerce_System.Models.Order>();
    string Badge(string? s) => s switch { "Pending" => "bg-amber-100 text-amber-700", "Confirmed" => "bg-blue-100 text-blue-700", "Shipped" => "bg-sky-100 text-sky-700", "Delivered" => "bg-emerald-100 text-emerald-700", "Cancelled" => "bg-rose-100 text-rose-700", _ => "bg-slate-100 text-slate-700" };
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">My Orders</h1>
        <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="text-sm text-primary hover:underline">Shop More</a>
    </div>

    @if (!orders.Any())
    {
        <div class="bg-white border border-dashed border-slate-300 rounded-2xl p-10 text-center"><p class="text-slate-600 mb-3">No orders yet.</p><a asp-area="Customer" asp-controller="Products" asp-action="Index" class="inline-flex px-4 py-2 rounded-lg bg-primary text-white">Start Shopping</a></div>
    }
    else
    {
        <div class="overflow-auto bg-white border border-slate-200 rounded-2xl">
            <table class="w-full text-sm">
                <thead class="bg-slate-50"><tr class="text-left"><th class="p-3">Order #</th><th class="p-3">Date</th><th class="p-3">Items</th><th class="p-3">Total</th><th class="p-3">Status</th><th class="p-3">Payment</th><th class="p-3">Actions</th></tr></thead>
                <tbody>
                @foreach (var o in orders)
                {
                    <tr class="border-t border-slate-100">
                        <td class="p-3">#@o.Id</td><td class="p-3">@o.CreatedAt.ToString("dd MMM yyyy")</td><td class="p-3">@(o.OrderItems?.Count ?? 0)</td><td class="p-3">@o.TotalAmount.ToString("0.00") EGP</td>
                        <td class="p-3"><span class="px-2 py-1 rounded-full text-xs @Badge(o.Status)">@o.Status</span></td>
                        <td class="p-3"><span class="px-2 py-1 rounded-full text-xs @Badge(o.PaymentStatus)">@o.PaymentStatus</span></td>
                        <td class="p-3"><div class="flex items-center gap-2"><a asp-area="Customer" asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" class="text-primary hover:underline">View</a>
                        @if (o.Status == "Pending") { <form asp-area="Customer" asp-controller="Orders" asp-action="Cancel" method="post" data-loading="true" class="inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@o.Id" /><button class="text-rose-600">Cancel</button></form> }
                        </div></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
