            </div>
            <div class="flex items-center gap-4">
                <div class="size-10 rounded-lg bg-cover bg-center" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuD7ZPyaeSWzjehelUZLfZmPUHlJ67YEm0C_6kTzRHYYz--Nz3_hft5OsusypVE3DOj6TCjPyfxqfFUNFeUIUJbVLhIutF2cbewNG9MhIETE978qzWW6ynYnapms8qlSN3EVmX0CI92xMAHX6_EWarGx6uI310Vq61NEzLvtCua_xVx0HgcPDl2qXRrlKXvwsjGdvVHxNf2Fl6NAYPf8E8Gx7zRv5hw8wt14PPecn6vP643Orx1_h7ouPQWhf3JM9HIi5DEZfK70NjkR')"></div>
