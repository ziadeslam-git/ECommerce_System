@using ECommerce_System.ViewModels.Admin
@model ProductVariantVM

@{
    ViewData["Title"] = "Add Variant";
    var productName = ViewData["ProductName"]?.ToString() ?? "";
    var productId   = Model.ProductId;
    var sizes       = new[] { "XS", "S", "M", "L", "XL", "XXL" };
}

<div class="max-w-2xl mx-auto space-y-6">

    <!-- Breadcrumb -->
    <div>
        <nav class="flex text-sm text-slate-500 mb-2 items-center gap-2">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
               class="hover:text-primary transition-colors">Products</a>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
               asp-route-productId="@productId"
               class="hover:text-primary transition-colors">@productName</a>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <span class="font-medium text-slate-900">Add Variant</span>
        </nav>
        <h1 class="text-3xl font-black tracking-tight">Add Variant</h1>
        <p class="text-slate-500 mt-1">Create a new size/color variant for <strong>@productName</strong>.</p>
    </div>

    <!-- Form -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <form asp-area="Admin" asp-controller="ProductVariants" asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="ProductId" type="hidden" />
            <input asp-for="ProductName" type="hidden" />

            <div class="space-y-5">

                <!-- Size + Color -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Size" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                        <select asp-for="Size"
                                class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                       focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all">
                            <option value="">— Select Size —</option>
                            @foreach (var s in sizes)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                        <span asp-validation-for="Size" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Color" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                        <input asp-for="Color"
                               class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                      focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all
                                      placeholder:text-slate-400"
                               placeholder="e.g. White, Black, Navy" autocomplete="off" />
                        <span asp-validation-for="Color" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- SKU -->
                <div>
                    <label asp-for="SKU" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                    <input asp-for="SKU" id="skuInput"
                           class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                  font-mono focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all
                                  placeholder:text-slate-400"
                           placeholder="e.g. PROD-001-M-WHITE" autocomplete="off" />
                    <p class="text-xs text-slate-400 mt-1">Unique Stock Keeping Unit — uppercase letters and hyphens.</p>
                    <span asp-validation-for="SKU" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Price + Stock -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Price" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-medium">$</span>
                            <input asp-for="Price" type="number" step="0.01" min="0.01"
                                   class="w-full rounded-lg border border-slate-200 bg-white pl-7 pr-4 py-2.5 text-sm
                                          focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                                   placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Price" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Stock" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                        <input asp-for="Stock" type="number" min="0"
                               class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                      focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                               placeholder="0" />
                        <span asp-validation-for="Stock" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- Active -->
                <div class="flex items-center gap-3">
                    <input asp-for="IsActive" type="checkbox" id="isActiveCheck"
                           class="size-4 rounded accent-primary" />
                    <label for="isActiveCheck" class="text-sm font-semibold text-slate-700">
                        Active (available for purchase)
                    </label>
                </div>

                <!-- Variant Images (Multiple) -->
                <div class="pt-4 border-t border-slate-100">
                    <h3 class="text-sm font-bold text-slate-900 mb-1">Variant Images <span class="font-normal text-slate-400">(Optional — multiple allowed)</span></h3>
                    <p class="text-xs text-slate-400 mb-4">First image will automatically be the Main Image for this variant.</p>
                    
                    <div id="imageDropZone"
                         class="relative border-2 border-dashed border-slate-200 rounded-xl p-6 text-center
                                hover:border-primary/50 hover:bg-primary/2 transition-all cursor-pointer">
                        <input asp-for="ImageFiles" type="file" accept="image/*" multiple id="imageFilesInput"
                               class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                        <span class="material-symbols-outlined text-3xl text-slate-300 mb-2 block">add_photo_alternate</span>
                        <p class="text-sm font-semibold text-slate-500">Click or drag & drop images here</p>
                        <p class="text-xs text-slate-400 mt-1">PNG, JPG, WEBP — multiple files supported</p>
                    </div>

                    <!-- Image Previews -->
                    <div id="imagePreviews" class="mt-4 grid grid-cols-3 gap-3 hidden"></div>

                    <div class="flex items-center gap-3 mt-4">
                        <input asp-for="SetAsMainProductImage" type="checkbox" id="setMainCheck"
                               class="size-4 rounded accent-primary" />
                        <label for="setMainCheck" class="text-sm font-medium text-slate-700">
                            @Html.DisplayNameFor(m => m.SetAsMainProductImage)
                        </label>
                    </div>
                </div>

            </div>

            <!-- Actions -->
            <div class="flex items-center justify-end gap-3 mt-8 pt-6 border-t border-slate-100">
                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
                   asp-route-productId="@productId"
                   class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 text-sm font-semibold
                          hover:bg-slate-50 transition-colors">
                    Cancel
                </a>
                <button type="submit"
                        class="flex items-center gap-2 px-6 py-2.5 rounded-lg bg-primary hover:bg-primary/90
                               text-white text-sm font-bold shadow-lg shadow-primary/20 transition-all active:scale-95">
                    <span class="material-symbols-outlined text-base">add</span>
                    Add Variant
                </button>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const input    = document.getElementById('imageFilesInput');
        const previews = document.getElementById('imagePreviews');

        input.addEventListener('change', function () {
            previews.innerHTML = '';
            if (!this.files || this.files.length === 0) {
                previews.classList.add('hidden');
                return;
            }
            previews.classList.remove('hidden');
            Array.from(this.files).forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = e => {
                    const div = document.createElement('div');
                    div.className = 'relative rounded-xl overflow-hidden border-2 aspect-square ' +
                                    (index === 0 ? 'border-primary shadow-md shadow-primary/20' : 'border-slate-200');
                    div.innerHTML = `
                        <img src="${e.target.result}" class="w-full h-full object-cover" />
                        ${index === 0 ? '<div class="absolute top-1.5 left-1.5 bg-primary text-white text-[9px] font-black px-1.5 py-0.5 rounded">MAIN</div>' : ''}
                        <div class="absolute bottom-0 inset-x-0 bg-black/50 text-white text-[10px] truncate px-2 py-1">${file.name}</div>
                    `;
                    previews.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}
