@using ECommerce_System.ViewModels.Customer
@model CartIndexVM

@{
    ViewData["Title"] = "My Cart";
}

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Shopping Cart</h1>
    
    @if (!Model.Items.Any())
    {
        <div class="bg-white p-8 rounded-lg shadow-sm border border-slate-200 text-center">
            <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">shopping_cart</span>
            <h2 class="text-xl font-semibold text-slate-700">Your cart is currently empty.</h2>
            <p class="text-slate-500 mt-2">Start adding items to proceed with checkout.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-4">
                @foreach (var item in Model.Items)
                {
                    <div class="bg-white p-4 rounded-lg shadow-sm border border-slate-200 flex items-center gap-4">
                        <div class="w-24 h-24 bg-slate-100 rounded flex-shrink-0">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.ProductName" class="w-full h-full object-cover rounded" />
                            }
                        </div>
                        <div class="flex-grow">
                            <h3 class="font-semibold text-lg text-slate-800">@item.ProductName</h3>
                            <p class="text-sm text-slate-500">Size: @item.Size | Color: @item.Color</p>
                            <p class="font-bold text-primary mt-2">$@item.UnitPrice.ToString("0.00")</p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-semibold mb-2">Qty: @item.Quantity</p>
                            <form asp-action="RemoveItem" method="post">
                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                <button type="submit" class="text-red-500 hover:text-red-700 text-sm font-medium">Remove</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
            
            <div class="bg-white p-6 rounded-lg shadow-sm border border-slate-200 h-fit">
                <h3 class="text-xl font-bold mb-4">Order Summary</h3>
                <div class="flex justify-between mb-2 text-slate-600">
                    <span>Subtotal (@Model.TotalItemCount items)</span>
                    <span>$@Model.Subtotal.ToString("0.00")</span>
                </div>
                @if (Model.DiscountAmount > 0)
                {
                    <div class="flex justify-between mb-2 text-emerald-600">
                        <span>Discount (@Model.AppliedCouponCode)</span>
                        <span>-$@Model.DiscountAmount.ToString("0.00")</span>
                    </div>
                }
                <hr class="my-4 border-slate-200" />
                <div class="flex justify-between mb-6 font-bold text-xl text-slate-800">
                    <span>Total</span>
                    <span>$@Model.Total.ToString("0.00")</span>
                </div>
                <button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3 rounded-lg transition-colors">
                    Proceed to Checkout
                </button>
            </div>
        </div>
    }


</div>
