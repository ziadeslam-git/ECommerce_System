@model ECommerce_System.Models.Cart
@{
    ViewData["Title"] = "Cart";
    var items = Model?.Items ?? new List<ECommerce_System.Models.CartItem>();
    decimal subtotal = items.Sum(i => i.PriceSnapshot * i.Quantity);
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">Your Cart</h1>
        <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="text-sm text-primary hover:underline">Continue Shopping</a>
    </div>

    @if (!items.Any())
    {
        <div class="bg-white border border-dashed border-slate-300 rounded-2xl p-12 text-center space-y-4">
            <p class="text-2xl">🛒</p><h2 class="text-xl font-semibold">Your cart is empty</h2>
            <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="inline-flex px-5 py-2 rounded-lg bg-primary text-white">Browse Products</a>
        </div>
    }
    else
    {
        <div class="grid lg:grid-cols-5 gap-6">
            <div class="lg:col-span-3 bg-white rounded-2xl border border-slate-200 divide-y divide-slate-200">
                @foreach (var item in items)
                {
                    <div class="p-4 flex gap-4">
                        <img src="@(item.ProductVariant?.Images?.FirstOrDefault(i => i.IsMain)?.ImageUrl ?? item.ProductVariant?.Images?.FirstOrDefault()?.ImageUrl ?? item.ProductVariant?.Product?.Images?.FirstOrDefault(i => i.IsMain)?.ImageUrl ?? item.ProductVariant?.Product?.Images?.FirstOrDefault()?.ImageUrl ?? "https://placehold.co/120")" class="h-24 w-24 rounded-lg object-cover bg-slate-100" alt="@item.ProductVariant?.Product?.Name" />
                        <div class="flex-1 space-y-1">
                            <p class="font-semibold">@item.ProductVariant?.Product?.Name</p>
                            <p class="text-xs text-slate-500">Variant: @(item.ProductVariant?.Size ?? "M") / @(item.ProductVariant?.Color ?? "Black")</p>
                            <p class="text-sm">@item.PriceSnapshot.ToString("0.00") EGP</p>
                            <form asp-area="Customer" asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="flex items-center gap-2" data-loading="true">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <input type="number" min="1" name="quantity" value="@item.Quantity" class="w-20 rounded-lg border-slate-300" />
                                <button class="text-xs px-3 py-1 rounded border border-slate-300">Update</button>
                            </form>
                        </div>
                        <div class="text-right space-y-2">
                            <p class="font-semibold">@((item.PriceSnapshot * item.Quantity).ToString("0.00"))</p>
                            <form asp-area="Customer" asp-controller="Cart" asp-action="Remove" method="post" data-loading="true">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <button class="text-rose-600 text-sm">Remove</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
            <aside class="lg:col-span-2 bg-white rounded-2xl border border-slate-200 p-5 h-fit space-y-4">
                <h2 class="font-semibold">Order Summary</h2>
                <div class="flex justify-between text-sm"><span>Subtotal</span><span>@subtotal.ToString("0.00") EGP</span></div>
                <form asp-area="Customer" asp-controller="Cart" asp-action="ApplyCoupon" method="post" class="flex gap-2" data-loading="true">
                    @Html.AntiForgeryToken()
                    <input type="text" name="couponCode" class="flex-1 rounded-lg border-slate-300" placeholder="Coupon code" />
                    <button class="px-3 rounded-lg border border-slate-300">Apply</button>
                </form>
                <div class="flex justify-between font-bold text-lg"><span>Total</span><span>@subtotal.ToString("0.00") EGP</span></div>
                <a asp-area="Customer" asp-controller="Cart" asp-action="Checkout" class="block text-center rounded-lg bg-primary py-3 text-white font-semibold">Proceed to Checkout</a>
            </aside>
        </div>
    }
</section>
