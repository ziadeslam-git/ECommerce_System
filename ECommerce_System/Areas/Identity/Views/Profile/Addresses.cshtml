@model IEnumerable<ECommerce_System.Models.Address>
@{
    ViewData["Title"] = "My Addresses";
    Layout = "_ProfileLayout";
}

<!-- Panel Header -->
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100">My Addresses</h1>
        <p class="text-slate-500 text-sm">Manage your delivery locations</p>
    </div>
    <a asp-action="AddAddress" class="flex items-center gap-2 bg-primary hover:bg-primary/90 text-white px-5 py-2.5 rounded-lg font-medium transition-all shadow-lg shadow-primary/20">
        <span class="material-symbols-outlined text-xl">add</span>
        <span>Add New Address</span>
    </a>
</div>

<!-- Success Alert -->
@if (TempData["Success"] != null || TempData["success"] != null)
{
    <div class="bg-emerald-100 dark:bg-emerald-900/30 border border-emerald-400 dark:border-emerald-700 text-emerald-700 dark:text-emerald-400 px-4 py-3 rounded-xl relative mb-6 flex justify-between items-center" role="alert">
        <span class="block sm:inline font-medium text-sm">@(TempData["Success"] ?? TempData["success"])</span>
        <button type="button" class="text-emerald-700 dark:text-emerald-400 hover:opacity-75" onclick="this.parentElement.style.display='none';">
            <span class="material-symbols-outlined text-sm">close</span>
        </button>
    </div>
}

<!-- Address Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    @if (!Model.Any())
    {
        <div class="col-span-full bg-slate-50 dark:bg-slate-800/50 p-8 rounded-xl text-center border-2 border-dashed border-slate-200 dark:border-slate-700">
            <span class="material-symbols-outlined text-4xl text-slate-400 mb-2">location_off</span>
            <p class="text-slate-500">You don't have any saved addresses yet.</p>
        </div>
    }

    @foreach (var address in Model)
    {
        <div class="bg-white dark:bg-slate-900 border @(address.IsDefault ? "border-primary/50 ring-1 ring-primary/50" : "border-slate-200 dark:border-slate-800") rounded-xl p-6 relative flex flex-col justify-between hover:shadow-md transition-shadow">
            <div>
                <div class="flex justify-between items-start mb-4">
                    <div class="bg-primary/10 text-primary p-3 rounded-full">
                        <span class="material-symbols-outlined fill-1">home</span>
                    </div>
                    @if (address.IsDefault)
                    {
                        <span class="bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full border border-emerald-200 dark:border-emerald-800">
                            Default
                        </span>
                    }
                </div>
                <h4 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-1">@address.FullName</h4>
                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-1">@address.Street</p>
                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4">@address.City, @address.State @address.PostalCode, @address.Country</p>
                
                <div class="flex items-center gap-2 text-slate-500 text-xs mb-6">
                    <span class="material-symbols-outlined text-sm">phone</span>
                    <span>@address.PhoneNumber</span>
                </div>
            </div>
            
            <div class="flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-800">
                @if (address.IsDefault)
                {
                    <span class="text-emerald-600 dark:text-emerald-400 text-xs font-semibold flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">check_circle</span>
                        Main Delivery Point
                    </span>
                }
                else
                {
                    <form asp-action="SetDefaultAddress" method="post" class="inline mb-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@address.Id" />
                        <button type="submit" class="text-primary hover:underline text-xs font-semibold">Set as Default</button>
                    </form>
                }
                
                <div class="flex items-center gap-3">
                    <a asp-action="EditAddress" asp-route-id="@address.Id" class="text-slate-400 hover:text-primary transition-colors" title="Edit">
                        <span class="material-symbols-outlined">edit</span>
                    </a>
                    <form asp-action="DeleteAddress" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this address?');">
                        <input type="hidden" name="id" value="@address.Id" />
                        <button type="submit" class="text-rose-400 hover:text-rose-600 transition-colors" title="Delete">
                            <span class="material-symbols-outlined">delete</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
