@model CheckoutVM
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    ViewData["Title"] = SR["Checkout"];
    var items = Model?.Items ?? [];
    var addresses = Model?.Addresses ?? [];
    var subtotal = Model?.Subtotal ?? 0m;
    var total = Model?.Total ?? subtotal;
    var selectedAddressId = Model?.AddressId ?? Model?.DefaultAddressId;
    var couponCode = Model?.CouponCode ?? string.Empty;
    var paymentMethod = Model?.PaymentMethod ?? "CashOnDelivery";
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-bold">@SR["Checkout"]</h1>
        <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="inline-flex items-center gap-1 text-sm text-primary hover:underline"><span class="material-symbols-outlined text-base">arrow_back</span>@SR["BackToCart"]</a>
    </div>

    <form id="place-order-form" asp-area="Customer" asp-controller="Orders" asp-action="PlaceOrder" method="post" data-loading="true" class="grid gap-6 lg:grid-cols-5">
        @Html.AntiForgeryToken()
        <div class="space-y-6 rounded-2xl border border-slate-200 bg-white p-5 lg:col-span-3">
            <div>
                <h2 class="mb-3 font-semibold">@SR["ShippingAddress"]</h2>
                @if (!addresses.Any())
                {
                    <div class="space-y-3 rounded-xl border border-dashed border-slate-300 p-4 text-sm text-slate-600">
                        <p>@SR["AddNewAddress"]</p>
                        <a asp-area="Identity" asp-controller="Profile" asp-action="AddAddress" class="inline-flex rounded-lg bg-primary px-4 py-2 font-semibold text-white">
                            + @SR["AddNewAddress"]
                        </a>
                    </div>
                }
                else
                {
                    <div class="space-y-3">
                        @foreach (var address in addresses)
                        {
                            <label class="flex items-start gap-3 rounded-lg border border-slate-200 p-3 @(address.Id == selectedAddressId ? "border-primary bg-indigo-50" : "")">
                                <input type="radio" name="addressId" value="@address.Id" class="mt-1" @(address.Id == selectedAddressId ? "checked" : null) />
                                <span class="space-y-1 text-sm">
                                    <span class="block font-semibold text-slate-900">
                                        @address.FullName
                                        @if (address.IsDefault)
                                        {
                                            <span class="ml-2 rounded-full bg-primary/10 px-2 py-0.5 text-xs text-primary">Default</span>
                                        }
                                    </span>
                                    <span class="block text-slate-600">@address.PhoneNumber</span>
                                    <span class="block text-slate-500">@address.DisplayLine</span>
                                </span>
                            </label>
                        }
                    </div>
                    <div class="pt-2">
                        <a asp-area="Identity" asp-controller="Profile" asp-action="AddAddress" class="text-sm text-primary hover:underline">+ @SR["AddNewAddress"]</a>
                    </div>
                }
            </div>

            <div class="space-y-3">
                <h2 class="font-semibold">@SR["OrderSummary"]</h2>
                @foreach (var item in items)
                {
                    <div class="flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 p-3">
                        <img src="@(item.ImageUrl ?? "https://placehold.co/100")" alt="@item.ProductName" class="h-16 w-16 rounded-lg bg-white object-cover" />
                        <div class="flex-1 text-sm">
                            <p class="font-semibold text-slate-900">@item.ProductName</p>
                            <p class="text-slate-500">@item.Size / @item.Color</p>
                            <p class="text-slate-500">@item.Quantity x @item.DisplayPrice.ToString("0.00") EGP</p>
                        </div>
                        <p class="font-semibold text-slate-900">@item.LineTotal.ToString("0.00") EGP</p>
                    </div>
                }
            </div>

            <div class="space-y-3">
                <h2 class="font-semibold text-slate-900">Payment Method</h2>
                <div class="grid gap-3 sm:grid-cols-2">
                    <label class="cursor-pointer">
                        <input type="radio" name="paymentMethod" value="CashOnDelivery" class="sr-only peer" @(paymentMethod == "CashOnDelivery" ? "checked" : null) />
                        <span class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white p-4 text-sm transition peer-checked:border-primary peer-checked:bg-primary/5">
                            <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-primary">
                                <span class="material-symbols-outlined text-[20px]">payments</span>
                            </span>
                            <span class="space-y-1">
                                <span class="block font-semibold text-slate-900">@SR["CashOnDelivery"]</span>
                                <span class="block text-xs text-slate-500">Pay when your order arrives.</span>
                            </span>
                        </span>
                    </label>

                    <label class="cursor-pointer">
                        <input type="radio" name="paymentMethod" value="CreditCard" class="sr-only peer" @(paymentMethod == "CreditCard" ? "checked" : null) />
                        <span class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white p-4 text-sm transition peer-checked:border-primary peer-checked:bg-primary/5">
                            <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-sky-50 text-sky-600">
                                <span class="material-symbols-outlined text-[20px]">credit_card</span>
                            </span>
                            <span class="space-y-1">
                                <span class="block font-semibold text-slate-900">Payment Credit Card</span>
                                <span class="block text-xs text-slate-500">Stripe gateway checkout option.</span>
                            </span>
                        </span>
                    </label>
                </div>
                @if (paymentMethod == "CreditCard")
                {
                    <p class="text-xs text-slate-500">You will be redirected to Stripe to complete your card payment securely.</p>
                }
            </div>
        </div>

        <aside class="h-fit space-y-4 rounded-2xl border border-slate-200 bg-white p-5 lg:col-span-2">
            <h2 class="font-semibold">@SR["OrderSummary"]</h2>
            <div class="space-y-3 rounded-xl border border-slate-200 bg-slate-50 p-4">
                <div class="flex items-center justify-between gap-2">
                    <label for="couponCode" class="text-sm font-semibold text-slate-800">Discount Code</label>
                    @if (Model?.CouponApplied == true)
                    {
                        <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-semibold text-emerald-700">Applied</span>
                    }
                </div>

                <div class="flex gap-2">
                    <input id="couponCode"
                           name="couponCode"
                           value="@couponCode"
                           placeholder="Enter coupon code"
                           class="w-full rounded-xl border-slate-300 text-sm" />
                    <button type="submit"
                            formmethod="get"
                            formaction="@Url.Action("Checkout", "Orders", new { area = "Customer" })"
                            class="rounded-xl border border-primary/20 bg-primary/5 px-4 py-2 text-sm font-semibold text-primary transition hover:bg-primary/10">
                        Apply
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model?.CouponMessage))
                {
                    <p class="text-sm @(Model?.CouponApplied == true ? "text-emerald-600" : "text-rose-600")">
                        @Model?.CouponMessage
                    </p>
                }
            </div>

            <div class="space-y-1 text-sm text-slate-600">
                <p>@SR["ItemsCount"]: @Model?.ItemsCount</p>
                <p>@SR["Subtotal"]: @subtotal.ToString("0.00") EGP</p>
                <p>@SR["Discount"]: @((Model?.DiscountAmount ?? 0m).ToString("0.00")) EGP</p>
                @if (Model?.CouponApplied == true && !string.IsNullOrWhiteSpace(Model.CouponCode))
                {
                    <p class="text-emerald-600">Code: @Model.CouponCode</p>
                }
            </div>
            <div class="flex justify-between text-lg font-bold"><span>@SR["Total"]</span><span>@total.ToString("0.00") EGP</span></div>
            <button type="submit" class="w-full rounded-lg bg-primary py-3 font-semibold text-white">@SR["PlaceOrder"]</button>
        </aside>
    </form>
</section>
