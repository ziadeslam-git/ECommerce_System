                <span class="mt-4 text-[11px] text-slate-400 font-medium">Mar</span>
            </div>
            <div class="relative flex-1 group h-full flex flex-col justify-end items-center">
                <div class="w-full max-w-[40px] bg-primary/40 group-hover:bg-primary rounded-t-lg transition-all duration-300" style="height: 60%;"></div>
                <span class="mt-4 text-[11px] text-slate-400 font-medium">Apr</span>
            </div>
            <div class="relative flex-1 group h-full flex flex-col justify-end items-center">
                <div class="w-full max-w-[40px] bg-primary/40 group-hover:bg-primary rounded-t-lg transition-all duration-300" style="height: 85%;"></div>
                <span class="mt-4 text-[11px] text-slate-400 font-medium">May</span>
            </div>
            <div class="relative flex-1 group h-full flex flex-col justify-end items-center">
                <div class="w-full max-w-[40px] bg-primary rounded-t-lg transition-all duration-300" style="height: 100%;"></div>
                <span class="mt-4 text-[11px] text-slate-800 dark:text-slate-100 font-bold">Jun</span>
            </div>
            <div class="relative flex-1 group h-full flex flex-col justify-end items-center">
                <div class="w-full max-w-[40px] bg-primary/40 group-hover:bg-primary rounded-t-lg transition-all duration-300" style="height: 70%;"></div>
                <span class="mt-4 text-[11px] text-slate-400 font-medium">Jul</span>
            </div>
            <div class="relative flex-1 group h-full flex flex-col justify-end items-center">
