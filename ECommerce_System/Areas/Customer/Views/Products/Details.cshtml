@model ECommerce_System.ViewModels.Customer.ProductController.ProductDetailsVM
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    var isAr = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isAr ? ar : en;
    var product  = Model?.Product;
    var reviews  = Model?.Reviews  ?? [];
    var related  = Model?.RelatedProducts ?? [];
    var allVariants = product?.Variants?.OrderBy(v => v.Size).ThenBy(v => v.Color).ToList() ?? [];
    var availableVariants = allVariants.Where(v => v.IsActive && v.Stock > 0).OrderBy(v => v.Price).ToList();
    var firstAvailableVariant = availableVariants.FirstOrDefault();
    var sizes    = allVariants.Select(v => v.Size).Distinct().OrderBy(s => s).ToList();
    var colors   = allVariants.Select(v => v.Color).Distinct().OrderBy(c => c).ToList();
    var mainImg  = product?.Images?.FirstOrDefault(i => i.IsMain)?.ImageUrl
                ?? product?.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault()?.ImageUrl
                ?? "https://placehold.co/900x900";
    var minPrice     = availableVariants.Select(v => (decimal?)v.Price).OrderBy(p => p).FirstOrDefault();
    var displayPrice = (minPrice.HasValue && minPrice > 0) ? minPrice.Value : product?.BasePrice ?? 0m;
    var hasStock     = availableVariants.Any();
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    ViewData["Title"] = product?.Name ?? T("Product Details", "تفاصيل المنتج");
}

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">
    <a asp-area="Customer" asp-controller="Products" asp-action="Index"
       class="inline-flex items-center gap-1 text-sm text-primary hover:underline">
        <span class="material-symbols-outlined text-base">arrow_back</span>@T("Products", "المنتجات")
    </a>

    <div class="grid lg:grid-cols-2 gap-8">

        <div class="space-y-3">
            <div class="aspect-square bg-white border border-slate-200 rounded-2xl overflow-hidden">
                <img id="mainProductImg" src="@mainImg" class="w-full h-full object-cover"
                     alt="@(product?.Name ?? "Product")" />
            </div>
            <div class="grid grid-cols-4 gap-2">
                @foreach (var img in product?.Images?.OrderBy(i => i.DisplayOrder).Take(4) ?? [])
                {
                    <img src="@img.ImageUrl" alt="@product?.Name"
                         class="aspect-square rounded-xl border border-slate-200 bg-white object-cover cursor-pointer hover:border-primary transition"
                         onclick="document.getElementById('mainProductImg').src='@img.ImageUrl'" />
                }
            </div>
        </div>

        <div class="space-y-5">
            <h1 class="text-3xl font-bold">@(product?.Name ?? T("Product", "المنتج"))</h1>

            <div class="text-amber-500">
                @{
                    int stars = (int)Math.Round(product?.AverageRating ?? 0);
                    for (int s = 1; s <= 5; s++) { <text>@(s <= stars ? "★" : "☆")</text> }
                }
                <span class="text-slate-500 text-sm ms-1">(@reviews.Count @T("Reviews", "تقييم"))</span>
            </div>

            <p class="text-2xl font-extrabold text-primary">@displayPrice.ToString("0.00") EGP</p>

            @if (!hasStock)
            {
                <span class="inline-block bg-red-100 text-red-600 text-xs font-bold px-3 py-1 rounded-full">
                    @T("Out of stock", "نفذ المخزون")
                </span>
            }

            <div id="variant-stock-notice"
                 class="@(hasStock ? "hidden" : "block") rounded-2xl border px-4 py-3 text-sm font-medium @(hasStock ? "border-rose-200 bg-rose-50 text-rose-700" : "border-rose-200 bg-rose-50 text-rose-700")">
                @T("Out of stock. Restock soon.", "نفد المخزون حاليًا وسيتم توفيره قريبًا.")
            </div>

            <form asp-area="Customer" asp-controller="Cart" asp-action="AddToCart"
                  method="post" data-ajax-form="cart" class="space-y-4" id="add-to-cart-form">
                @Html.AntiForgeryToken()
                @* productVariantId resolved by JS from selected size + color *@
                <input type="hidden" id="selectedVariantId" name="productVariantId" value="" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                @if (sizes.Any())
                {
                    <div>
                        <p class="font-medium mb-2">@T("Size", "المقاس")</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var s in sizes)
                            {
                                <label class="cursor-pointer">
                                    <input type="radio" name="size" value="@s" class="sr-only peer" data-size-input
                                           @(firstAvailableVariant?.Size == s ? "checked" : "") />
                                    <span data-option-pill data-size-pill
                                          class="px-3 py-2 rounded-lg border border-slate-300 text-sm
                                                 peer-checked:border-primary peer-checked:bg-primary/10
                                                 hover:border-primary transition block">@s</span>
                                </label>
                            }
                        </div>
                    </div>
                }

                @if (colors.Any())
                {
                    <div>
                        <p class="font-medium mb-2">@T("Color", "اللون")</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var c in colors)
                            {
                                <label class="cursor-pointer">
                                    <input type="radio" name="color" value="@c" class="sr-only peer" data-color-input
                                           @(firstAvailableVariant?.Color == c ? "checked" : "") />
                                    <span data-option-pill data-color-pill
                                          class="px-3 py-1 rounded-full border border-slate-300 text-xs
                                                 peer-checked:border-primary peer-checked:bg-primary/10
                                                 hover:border-primary transition block">@c</span>
                                </label>
                            }
                        </div>
                    </div>
                }

                <div class="flex items-center gap-2">
                    <button type="button" class="qty-btn h-10 w-10 rounded-lg border border-slate-300 font-bold" data-dir="minus">-</button>
                    <input id="qty" name="quantity" value="1" min="1" type="number"
                           class="w-16 text-center rounded-lg border-slate-300" />
                    <button type="button" class="qty-btn h-10 w-10 rounded-lg border border-slate-300 font-bold" data-dir="plus">+</button>
                </div>

                <div class="flex flex-col sm:flex-row gap-3">
                    <button type="submit"
                            id="add-to-cart-submit"
                            @(hasStock ? null : "disabled")
                            class="px-5 py-3 rounded-lg bg-primary text-white font-semibold hover:bg-primary/90 transition">
                        @T("Add to Cart", "أضف للسلة")
                    </button>
                </div>
            </form>

            @* Separate wishlist form — Toggle takes productId, not variantId *@
            <form asp-area="Customer" asp-controller="Wishlist" asp-action="Toggle"
                  method="post"
                  data-ajax-form="wishlist"
                  data-active-text="@T("In Wishlist", "في المفضلة")"
                  data-inactive-text="@T("Add to Wishlist", "أضف للمفضلة")"
                  data-wishlist-active="@(Model?.IsInWishlist == true ? "true" : "false")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@(product?.Id ?? 0)" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <button type="submit"
                        data-wishlist-button
                        class="w-full sm:w-auto px-5 py-3 rounded-lg border border-slate-300
                               font-semibold hover:border-primary hover:text-primary transition">
                    @(Model?.IsInWishlist == true ? T("In Wishlist", "في المفضلة") : T("Add to Wishlist", "أضف للمفضلة"))
                </button>
            </form>

            @if (!string.IsNullOrWhiteSpace(product?.Description))
            {
                <div class="border-t border-slate-200 pt-4">
                    <p class="text-slate-600">@product.Description</p>
                </div>
            }
        </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">

        <div class="bg-white border border-slate-200 rounded-2xl p-5">
            <h2 class="text-xl font-bold mb-4">@T("Reviews", "التقييمات")</h2>
            @if (!reviews.Any())
            {
                <p class="text-slate-500 text-sm">@T("No reviews yet.", "لا توجد تقييمات بعد.")</p>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var review in reviews)
                    {
                        <div class="border border-slate-200 rounded-lg p-3">
                            <div class="flex items-center justify-between">
                                <span class="text-amber-500 text-sm">
                                    @for (int s = 1; s <= 5; s++) { <text>@(s <= review.Rating ? "★" : "☆")</text> }
                                </span>
                                <span class="text-xs text-slate-500">@review.CreatedAt.ToString("dd MMM yyyy")</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(review.Comment))
                            {
                                <p class="text-sm text-slate-700 mt-2">@review.Comment</p>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl p-5">
            <h2 class="text-xl font-bold mb-4">@T("Submit a Review", "أضف تقييمك")</h2>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-area="Customer" asp-controller="Reviews" asp-action="Submit"
                      method="post" data-loading="true" class="space-y-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@product?.Id" />
                    <div>
                        <label class="text-sm font-medium">@T("Rating", "التقييم")</label>
                        <select name="rating" class="mt-1 w-full rounded-lg border-slate-300">
                            @for (int r = 5; r >= 1; r--)
                            {
                                <option value="@r">@r ★</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="text-sm font-medium">@T("Comment", "تعليق")</label>
                        <textarea name="comment" rows="4"
                                  class="mt-1 w-full rounded-lg border-slate-300"
                                  placeholder="@T("Write your feedback...", "اكتب تقييمك...")"></textarea>
                    </div>
                    <button type="submit"
                            class="px-5 py-3 rounded-lg bg-primary text-white font-semibold hover:bg-primary/90 transition">
                        @T("Submit Review", "إرسال التقييم")
                    </button>
                </form>
            }
            else
            {
                <p class="text-sm text-slate-600">
                    @T("Please", "من فضلك")
                    <a asp-area="Identity" asp-controller="Account" asp-action="Login"
                       class="text-primary underline">@T("login", "سجل دخولك")</a>
                    @T("to submit a review.", "لإضافة تقييم.")
                </p>
            }
        </div>
    </div>

    @if (related.Any())
    {
        <div>
            <h2 class="text-xl font-bold mb-4">@T("Related Products", "منتجات مشابهة")</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                @foreach (var rp in related)
                {
                    var rpImg = rp.Images?.FirstOrDefault(i => i.IsMain)?.ImageUrl
                             ?? rp.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault()?.ImageUrl
                             ?? "https://placehold.co/400x400";
                    <a asp-area="Customer" asp-controller="Products" asp-action="Details"
                       asp-route-id="@rp.Id"
                       class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-lg transition block">
                        <img src="@rpImg" alt="@rp.Name"
                             class="aspect-[4/5] w-full object-cover" loading="lazy" />
                        <div class="p-3">
                            <p class="font-semibold text-sm line-clamp-1">@rp.Name</p>
                            <p class="text-primary font-bold text-sm">@rp.BasePrice.ToString("0.00") EGP</p>
                        </div>
                    </a>
                }
            </div>
        </div>
    }
</section>

@section Scripts {
    @{
        var variantsJson = System.Text.Json.JsonSerializer.Serialize(
            product?.Variants?.Select(v => new
            {
                id    = v.Id,
                size  = v.Size,
                color = v.Color,
                stock = v.Stock,
                isActive = v.IsActive
            }) ?? Enumerable.Empty<object>()
        );
    }
    <script>
        const _variants = @Html.Raw(variantsJson);

        const qtyInput = document.getElementById('qty');
        const addToCartButton = document.getElementById('add-to-cart-submit');
        const selectedVariantInput = document.getElementById('selectedVariantId');
        const stockNotice = document.getElementById('variant-stock-notice');

        function isAvailableVariant(variant) {
            return !!variant && variant.isActive && variant.stock > 0;
        }

        function getSelectedValue(name) {
            return document.querySelector(`input[name="${name}"]:checked`)?.value ?? null;
        }

        function getMatchingVariants(size, color) {
            return _variants.filter(v =>
                (size === null || v.size === size) &&
                (color === null || v.color === color)
            );
        }

        function getAvailableVariants(size, color) {
            return getMatchingVariants(size, color).filter(isAvailableVariant);
        }

        function setOptionAvailability(inputs, counterpartName, ownName) {
            const counterpartValue = getSelectedValue(counterpartName);

            inputs.forEach(input => {
                const ownValue = input.value;
                const available = ownName === 'size'
                    ? getAvailableVariants(ownValue, counterpartValue).length > 0
                    : getAvailableVariants(counterpartValue, ownValue).length > 0;
                const pill = input.parentElement?.querySelector('[data-option-pill]');

                input.disabled = !available;
                input.parentElement?.classList.toggle('cursor-not-allowed', !available);
                input.parentElement?.classList.toggle('cursor-pointer', available);

                if (pill) {
                    pill.classList.toggle('opacity-40', !available);
                    pill.classList.toggle('grayscale', !available);
                    pill.classList.toggle('bg-slate-100', !available);
                    pill.classList.toggle('text-slate-400', !available);
                    pill.classList.toggle('border-slate-200', !available);
                    pill.classList.toggle('hover:border-primary', available);
                }
            });
        }

        function ensureValidSelection(name) {
            const inputs = Array.from(document.querySelectorAll(`input[name="${name}"]`));
            const checked = inputs.find(input => input.checked && !input.disabled);
            if (checked) return;

            inputs.forEach(input => input.checked = false);
            const firstEnabled = inputs.find(input => !input.disabled);
            if (firstEnabled) {
                firstEnabled.checked = true;
            }
        }

        function updateStockNotice(message, isVisible) {
            if (!stockNotice) return;
            stockNotice.textContent = message;
            stockNotice.classList.toggle('hidden', !isVisible);
            stockNotice.classList.toggle('block', isVisible);
        }

        function resolveVariant() {
            setOptionAvailability(document.querySelectorAll('input[name="size"]'), 'color', 'size');
            ensureValidSelection('size');

            setOptionAvailability(document.querySelectorAll('input[name="color"]'), 'size', 'color');
            ensureValidSelection('color');

            setOptionAvailability(document.querySelectorAll('input[name="size"]'), 'color', 'size');
            ensureValidSelection('size');

            const size = getSelectedValue('size');
            const color = getSelectedValue('color');
            const match = getMatchingVariants(size, color)[0];

            selectedVariantInput.value = isAvailableVariant(match) ? match.id : '';

            const availableStock = isAvailableVariant(match) ? match.stock : 0;
            qtyInput.max = availableStock > 0 ? availableStock : 1;

            if (parseInt(qtyInput.value || '1', 10) > qtyInput.max) {
                qtyInput.value = qtyInput.max;
            }

            const isDisabled = !isAvailableVariant(match);
            addToCartButton.disabled = isDisabled;
            addToCartButton.classList.toggle('opacity-50', isDisabled);
            addToCartButton.classList.toggle('cursor-not-allowed', isDisabled);

            if (isDisabled) {
                updateStockNotice('@T("Out of stock. Restock soon.", "نفد المخزون حاليًا وسيتم توفيره قريبًا.")', true);
            } else {
                updateStockNotice('', false);
            }
        }

        document.querySelectorAll('input[name="size"], input[name="color"]')
                .forEach(r => r.addEventListener('change', resolveVariant));

        document.querySelectorAll('.qty-btn').forEach(button => button.addEventListener('click', () => {
            const currentValue = parseInt(qtyInput.value || '1', 10);
            const maxValue = parseInt(qtyInput.max || '1', 10);
            const nextValue = button.dataset.dir === 'plus'
                ? Math.min(maxValue, currentValue + 1)
                : Math.max(1, currentValue - 1);

            qtyInput.value = nextValue;
        }));

        qtyInput.addEventListener('input', () => {
            const maxValue = parseInt(qtyInput.max || '1', 10);
            const sanitized = Math.max(1, Math.min(maxValue, parseInt(qtyInput.value || '1', 10) || 1));
            qtyInput.value = sanitized;
        });

        resolveVariant(); // initialise on page load
    </script>
}
