@{
    ViewData["Title"] = "Dashboard";
}

<!-- Section 1: Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Revenue Card -->
    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800 flex flex-col">
        <div class="flex justify-between items-start mb-4">
            <div class="p-2 bg-indigo-50 dark:bg-indigo-900/30 rounded-lg text-indigo-600 dark:text-indigo-400">
                <span class="material-symbols-outlined">payments</span>
            </div>
            <!-- Example Growth badge -->
            <span class="px-2 py-1 bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400 text-[11px] font-bold rounded-full">+12.5%</span>
        </div>
        <p class="text-slate-800 dark:text-slate-100 text-2xl font-bold">@(((decimal)ViewBag.TotalRevenue).ToString("C"))</p>
        <p class="text-slate-500 dark:text-slate-400 text-sm">Total Revenue</p>
    </div>
    
    <!-- Orders Card -->
    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800 flex flex-col">
        <div class="flex justify-between items-start mb-4">
            <div class="p-2 bg-amber-50 dark:bg-amber-900/30 rounded-lg text-amber-600 dark:text-amber-400">
                <span class="material-symbols-outlined">shopping_cart</span>
            </div>
            <!-- Dynamic Growth Badge could be added here -->
            <span class="px-2 py-1 bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400 text-[11px] font-bold rounded-full">+8.2%</span>
        </div>
        <p class="text-slate-800 dark:text-slate-100 text-2xl font-bold">@ViewBag.TotalOrders</p>
        <p class="text-slate-500 dark:text-slate-400 text-sm">Total Orders</p>
    </div>
    
    <!-- Products Card -->
    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800 flex flex-col">
        <div class="flex justify-between items-start mb-4">
            <div class="p-2 bg-purple-50 dark:bg-purple-900/30 rounded-lg text-purple-600 dark:text-purple-400">
                <span class="material-symbols-outlined">package</span>
            </div>
        </div>
        <p class="text-slate-800 dark:text-slate-100 text-2xl font-bold">@ViewBag.TotalProducts</p>
        <p class="text-slate-500 dark:text-slate-400 text-sm">Total Products</p>
    </div>
    
    <!-- Customers Card -->
    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800 flex flex-col">
        <div class="flex justify-between items-start mb-4">
            <div class="p-2 bg-teal-50 dark:bg-teal-900/30 rounded-lg text-teal-600 dark:text-teal-400">
                <span class="material-symbols-outlined">groups</span>
            </div>
        </div>
        <p class="text-slate-800 dark:text-slate-100 text-2xl font-bold">@ViewBag.TotalCustomers</p>
        <p class="text-slate-500 dark:text-slate-400 text-sm">Active Customers</p>
    </div>
</div>

<!-- Section 2: Split View -->
<div class="grid grid-cols-1 lg:grid-cols-10 gap-8">
    
    <!-- Left: Recent Orders Table (60%) -->
    <div class="lg:col-span-6 bg-white dark:bg-slate-900 rounded-xl border border-slate-100 dark:border-slate-800 shadow-sm overflow-hidden flex flex-col max-h-[460px]">
        <div class="p-6 flex justify-between items-center border-b border-slate-100 dark:border-slate-800">
            <h3 class="text-slate-800 dark:text-slate-100 font-bold">Recent Orders</h3>
            <a asp-controller="Orders" asp-action="Index" asp-area="Admin" class="text-primary text-sm font-medium hover:underline flex items-center gap-1">
                View all <span class="material-symbols-outlined !text-sm">arrow_forward</span>
            </a>
        </div>
        
        <div class="overflow-y-auto flex-1">
            <table class="w-full text-left border-collapse">
                <thead class="sticky top-0 bg-slate-50 dark:bg-slate-800/80 backdrop-blur-sm z-10">
                    <tr>
                        <th class="px-6 py-4 text-[13px] font-semibold text-slate-500 uppercase tracking-wider">Order ID</th>
                        <th class="px-6 py-4 text-[13px] font-semibold text-slate-500 uppercase tracking-wider">Customer</th>
                        <th class="px-6 py-4 text-[13px] font-semibold text-slate-500 uppercase tracking-wider">Amount</th>
                        <th class="px-6 py-4 text-[13px] font-semibold text-slate-500 uppercase tracking-wider text-right">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @if (ViewBag.RecentOrders != null && ((IEnumerable<ECommerce_System.Models.Order>)ViewBag.RecentOrders).Any())
                    {
                        var isEven = false;
                        foreach (var order in (IEnumerable<ECommerce_System.Models.Order>)ViewBag.RecentOrders)
                        {
                            var rowClass = isEven ? "bg-[#F8FAFC] dark:bg-slate-800/20 hover:bg-slate-100/50" : "hover:bg-slate-50/50 dark:hover:bg-slate-800/20";
                            isEven = !isEven;

                            string statusBg, statusText, statusDarkBg, statusDarkText;
                            switch (order.Status)
                            {
                                case ECommerce_System.Utilities.SD.Status_Delivered:
                                    statusBg = "bg-green-100"; statusText = "text-green-700"; statusDarkBg = "dark:bg-green-900/40"; statusDarkText = "dark:text-green-400"; break;
                                case ECommerce_System.Utilities.SD.Status_Processing:
                                    statusBg = "bg-amber-100"; statusText = "text-amber-700"; statusDarkBg = "dark:bg-amber-900/40"; statusDarkText = "dark:text-amber-400"; break;
                                case ECommerce_System.Utilities.SD.Status_Cancelled:
                                    statusBg = "bg-red-100"; statusText = "text-red-700"; statusDarkBg = "dark:bg-red-900/40"; statusDarkText = "dark:text-red-400"; break;
                                default:
                                    statusBg = "bg-slate-100"; statusText = "text-slate-700"; statusDarkBg = "dark:bg-slate-800"; statusDarkText = "dark:text-slate-400"; break;
                            }

                            <tr class="@rowClass transition-colors">
                                <td class="px-6 py-4 text-sm font-medium text-slate-800 dark:text-slate-100">#ORD-@order.Id</td>
                                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400">@(order.User?.FullName ?? order.Address?.FullName ?? "Unknown")</td>
                                <td class="px-6 py-4 text-sm font-semibold text-slate-800 dark:text-slate-100">@order.TotalAmount.ToString("C")</td>
                                <td class="px-6 py-4 text-right">
                                    <span class="px-2.5 py-1 text-[11px] font-bold rounded-full @statusBg @statusText @statusDarkBg @statusDarkText">@order.Status</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-8 text-center text-sm text-slate-500">No recent orders found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- Right: Top Products (40%) -->
    <div class="lg:col-span-4 bg-white dark:bg-slate-900 rounded-xl border border-slate-100 dark:border-slate-800 shadow-sm p-6 max-h-[460px] overflow-y-auto">
        <h3 class="text-slate-800 dark:text-slate-100 font-bold mb-6">Top Products</h3>
