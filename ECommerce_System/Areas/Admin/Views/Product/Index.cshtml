@using ECommerce_System.ViewModels.Admin
@model IEnumerable<ProductIndexVM>

@{
    ViewData["Title"] = "Products";
}

<div class="space-y-6">

    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <nav class="flex text-sm text-slate-500 mb-2 items-center gap-2">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="hover:text-primary transition-colors">Dashboard</a>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <span class="font-medium text-slate-900">Products</span>
            </nav>
            <h1 class="text-3xl font-black tracking-tight">Products</h1>
            <p class="text-slate-500 mt-1">Manage your product catalog, variants, and images.</p>
        </div>
        <a asp-area="Admin" asp-controller="Product" asp-action="Create"
           class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold py-2.5 px-6 rounded-lg shadow-lg shadow-primary/20 transition-all active:scale-[0.98]">
            <span class="material-symbols-outlined">add</span>
            New Product
        </a>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        @{
            var all        = Model.ToList();
            var active     = all.Count(p => p.IsActive);
            var totalStock = all.Sum(p => p.TotalStock);
            var withImages = all.Count(p => p.ImageCount > 0);
        }
        <div class="bg-white rounded-xl border border-slate-200 p-4 flex flex-col gap-1">
            <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">Total Products</span>
            <span class="text-2xl font-black text-slate-900">@all.Count</span>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-4 flex flex-col gap-1">
            <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">Active</span>
            <span class="text-2xl font-black text-emerald-600">@active</span>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-4 flex flex-col gap-1">
            <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">Total Stock</span>
            <span class="text-2xl font-black text-slate-900">@totalStock.ToString("N0")</span>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-4 flex flex-col gap-1">
            <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">With Images</span>
            <span class="text-2xl font-black text-primary">@withImages</span>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs font-bold uppercase tracking-wider">
                        <th class="py-4 px-6">Product</th>
                        <th class="py-4 px-6">Category</th>
                        <th class="py-4 px-6 text-right">Base Price</th>
                        <th class="py-4 px-6 text-center">Variants</th>
                        <th class="py-4 px-6 text-center">Stock</th>
                        <th class="py-4 px-6 text-center">Status</th>
                        <th class="py-4 px-6 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="py-16 text-center text-slate-400">
                                <span class="material-symbols-outlined text-5xl block mb-3">inventory_2</span>
                                <p class="font-medium">No products yet.</p>
                                <a asp-area="Admin" asp-controller="Product" asp-action="Create"
                                   class="text-primary hover:underline text-sm mt-1 inline-block">
                                    Create your first product →
                                </a>
                            </td>
                        </tr>
                    }
                    @foreach (var p in Model)
                    {
                        <tr class="hover:bg-primary/5 transition-colors group @(!p.IsActive ? "opacity-60 bg-slate-50" : "")">
                            <!-- Product + thumbnail -->
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <div class="size-12 rounded-lg bg-slate-100 overflow-hidden flex-shrink-0">
                                        @if (p.MainImageUrl is not null)
                                        {
                                            <img src="@p.MainImageUrl" alt="@p.Name"
                                                 class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center">
                                                <span class="material-symbols-outlined text-slate-300 text-2xl">image</span>
                                            </div>
                                        }
                                    </div>
                                    <div>
                                        <p class="font-bold text-slate-900 text-sm">@p.Name</p>
                                        @if (p.AverageRating > 0)
                                        {
                                            <div class="flex items-center gap-1 mt-0.5">
                                                <span class="material-symbols-outlined text-amber-400 text-sm" style="font-variation-settings:'FILL' 1">star</span>
                                                <span class="text-xs text-slate-400">@p.AverageRating.ToString("0.0")</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded font-semibold">
                                    @p.CategoryName
                                </span>
                            </td>
                            <td class="py-4 px-6 text-right font-semibold text-slate-900 text-sm">
                                $@p.BasePrice.ToString("0.00")
                            </td>
                            <td class="py-4 px-6 text-center">
                                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
                                   asp-route-productId="@p.Id"
                                   class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold
                                          @(p.VariantCount > 0 ? "bg-primary/10 text-primary hover:bg-primary/20" : "bg-slate-100 text-slate-400")
                                          transition-colors">
                                    @p.VariantCount
                                </a>
                            </td>
                            <td class="py-4 px-6 text-center">
                                <span class="text-sm font-semibold @(p.TotalStock > 10 ? "text-emerald-600" : p.TotalStock > 0 ? "text-amber-500" : "text-rose-500")">
                                    @p.TotalStock.ToString("N0")
                                </span>
                            </td>
                            <td class="py-4 px-6 text-center">
                                <form asp-area="Admin" asp-controller="Product" asp-action="ToggleActive" method="post" class="inline-block">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit"
                                            class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 @(p.IsActive ? "bg-emerald-500" : "bg-slate-300")"
                                            role="switch" aria-checked="@p.IsActive.ToString().ToLower()">
                                        <span aria-hidden="true"
                                              class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out @(p.IsActive ? "translate-x-5" : "translate-x-0")"></span>
                                    </button>
                                </form>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex justify-end gap-1">
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Details"
                                       asp-route-id="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-primary transition-colors" title="Details">
                                        <span class="material-symbols-outlined text-lg">visibility</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
                                       asp-route-productId="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-indigo-600 transition-colors" title="Manage Variants">
                                        <span class="material-symbols-outlined text-lg">layers</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="ProductImages" asp-action="Index"
                                       asp-route-productId="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-teal-600 transition-colors" title="Manage Images">
                                        <span class="material-symbols-outlined text-lg">image</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Edit"
                                       asp-route-id="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-primary transition-colors" title="Edit">
                                        <span class="material-symbols-outlined text-lg">edit</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Delete"
                                       asp-route-id="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-red-500 transition-colors" title="Deactivate">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Footer -->
        <div class="bg-slate-50 px-6 py-3 border-t border-slate-200">
            <p class="text-sm text-slate-500">
                Total: <span class="font-semibold text-slate-900">@Model.Count()</span> products
            </p>
        </div>
    </div>

</div>
