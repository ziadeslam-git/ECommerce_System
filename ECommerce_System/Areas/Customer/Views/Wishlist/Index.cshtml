@model WishlistIndexVM
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    ViewData["Title"] = SR["Wishlist"];
    var items = Model?.Items ?? [];
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">@SR["Wishlist"]</h1>
        <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="text-sm text-primary hover:underline">@SR["BrowseProducts"]</a>
    </div>

    @if (Model?.IsEmpty ?? true)
    {
        <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-12 text-center">
            <p class="mb-3 text-slate-600">@SR["WishlistEmpty"]</p>
            <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="inline-flex rounded-lg bg-primary px-4 py-2 text-white">@SR["StartShopping"]</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-4">
            @foreach (var item in items)
            {
                <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white transition hover:shadow-lg">
                    <a asp-area="Customer" asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="block aspect-[4/5] bg-slate-100">
                        <img src="@(item.ImageUrl ?? "https://placehold.co/600x700")" class="h-full w-full object-cover" alt="@item.ProductName" />
                    </a>
                    <div class="space-y-2 p-3">
                        <p class="line-clamp-1 font-semibold">@item.ProductName</p>
                        <p class="font-bold text-primary">@item.BasePrice.ToString("0.00") EGP</p>
                        <div class="flex gap-2">
                            <form asp-area="Customer" asp-controller="Wishlist" asp-action="Remove" method="post" class="flex-1" data-loading="true">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.WishlistItemId" />
                                <button class="w-full rounded-lg border border-rose-200 py-2 text-sm text-rose-700">@SR["Remove"]</button>
                            </form>
                            <form asp-area="Customer" asp-controller="Cart" asp-action="Add" method="post" class="flex-1" data-loading="true">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button class="w-full rounded-lg bg-primary py-2 text-sm text-white">@SR["MoveToCart"]</button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
