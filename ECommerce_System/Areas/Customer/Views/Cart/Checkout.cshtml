@model dynamic
@{
    ViewData["Title"] = "Checkout";
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">Checkout</h1>
        <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="text-sm text-primary hover:underline inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">arrow_back</span>Back to Cart</a>
    </div>

    <form asp-area="Customer" asp-controller="Orders" asp-action="PlaceOrder" method="post" data-loading="true" class="grid lg:grid-cols-5 gap-6">
        @Html.AntiForgeryToken()
        <div class="lg:col-span-3 bg-white rounded-2xl border border-slate-200 p-5 space-y-6">
            <div>
                <h2 class="font-semibold mb-3">Shipping Address</h2>
                <label class="flex items-start gap-3 p-3 border border-slate-200 rounded-lg"><input type="radio" name="addressId" value="1" checked /><span>Home - Cairo, Nasr City</span></label>
                <label class="flex items-start gap-3 p-3 border border-slate-200 rounded-lg mt-2"><input type="radio" name="addressId" value="2" /><span>Office - New Cairo</span></label>
                <details class="mt-3">
                    <summary class="cursor-pointer text-primary text-sm">+ Add new address</summary>
                    <div class="grid sm:grid-cols-2 gap-3 mt-3">
                        <input name="street" class="rounded-lg border-slate-300" placeholder="Street" />
                        <input name="city" class="rounded-lg border-slate-300" placeholder="City" />
                        <input name="governorate" class="rounded-lg border-slate-300" placeholder="Governorate" />
                        <input name="postalCode" class="rounded-lg border-slate-300" placeholder="Postal Code" />
                    </div>
                </details>
            </div>
            <div class="p-4 rounded-xl border border-indigo-100 bg-indigo-50 text-sm text-indigo-700 inline-flex items-center gap-2"><span class="material-symbols-outlined text-base">payments</span>Cash on Delivery</div>
        </div>

        <aside class="lg:col-span-2 bg-white rounded-2xl border border-slate-200 p-5 h-fit space-y-4">
            <h2 class="font-semibold">Order Summary</h2>
            <div class="text-sm text-slate-600 space-y-1"><p>Items: 3 products</p><p>Subtotal: 1,200.00 EGP</p><p>Discount: 0.00 EGP</p></div>
            <div class="flex justify-between font-bold text-lg"><span>Total</span><span>1,200.00 EGP</span></div>
            <button type="submit" class="w-full rounded-lg bg-primary py-3 text-white font-semibold">Place Order</button>
        </aside>
    </form>
</section>
